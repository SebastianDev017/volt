<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    {%- comment -%} Land at the top on every (re)load — defeat browser scroll restoration before anything paints. {%- endcomment -%}
    <script>
      if ('scrollRestoration' in history) { history.scrollRestoration = 'manual'; }
      window.scrollTo(0, 0);
    </script>
    {%- comment -%} VOLT 1.0.0 — build marker (re-sync nudge) {%- endcomment -%}
    <script>document.documentElement.classList.add('js');</script>

    {%- if settings.show_loader -%}
      <script>try{if({% if settings.loader_session_once %}true{% else %}false{% endif %} && sessionStorage.getItem('volt-loaded')){document.documentElement.classList.add('loader-skip');}}catch(e){}</script>
      <script src="{{ 'volt-loader.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- if settings.use_gsap != false -%}
      {%- # theme-check-disable RemoteAsset -%}
      <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
      <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
      {%- # theme-check-enable RemoteAsset -%}
    {%- endif -%}

    {%- if settings.use_gsap != false -%}
      {%- comment -%} GSAP motion config + anti-FOUC class (added before paint) {%- endcomment -%}
      <script>
        (function () {
          var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
          var respect = {% if settings.respect_reduced_motion != false %}true{% else %}false{% endif %};
          if (!reduced || !respect) {
            var d = document.documentElement;
            d.classList.add('gsap-anim');
            setTimeout(function () { d.classList.add('gsap-ready'); }, 2400);
          }
          window.VoltAnimConfig = {
            speed: {{ settings.animation_speed | default: 1 }},
            stagger: {{ settings.animation_stagger | default: 6 | divided_by: 100.0 }},
            parallaxIntensity: {{ settings.parallax_intensity | default: 30 }},
            ease: {{ settings.animation_ease | default: 'power3.out' | json }},
            respectReducedMotion: respect,
            smoother: {% if settings.use_scroll_smoother %}true{% else %}false{% endif %},
            smootherAmount: {{ settings.scroll_smooth_amount | default: 4 }}
          };
        })();
      </script>
    {%- endif -%}

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230D0C0B'/%3E%3Cpath d='M17 4 L8 18 H15 L13 28 L24 12 H16 Z' fill='%23D4FF00'/%3E%3C/svg%3E">

    {% comment %} Syne + DM Mono are not in the font_picker — self-hosted in assets/ (see css-variables). DM Sans loads via the font_picker. {% endcomment %}

    {% # Inlined CSS variables (settings → :root) %}
    {% render 'css-variables' %}

    {% # Theme stylesheet %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- if settings.page_transitions != false -%}
      <style>
        @view-transition { navigation: auto; }
        ::view-transition-old(root){ animation: 200ms ease both volt-vt-out; }
        ::view-transition-new(root){ animation: 250ms ease both volt-vt-in; }
        @keyframes volt-vt-out{ to{ opacity: 0; } }
        @keyframes volt-vt-in{ from{ opacity: 0; } }
        @media (prefers-reduced-motion: reduce){
          ::view-transition-old(root), ::view-transition-new(root){ animation: none; }
        }
      </style>
    {%- endif -%}

    {% render 'meta-tags' %}
    {{ content_for_header }}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'card.js' | asset_url }}" defer></script>
  </head>

  <body
    class="template-{{ request.page_type | default: template.name | handle }}{% if settings.enable_custom_cursor != false %} volt-cursor-enabled{% endif %}"
    data-smooth-scroll="{{ settings.smooth_scroll }}"
    data-animations="{{ settings.scroll_animations }}"
    data-transitions="{{ settings.page_transitions }}"
    data-gauge="{{ settings.gauge_animation }}"
    data-grain="{{ settings.grain_texture }}"
  >
    {%- if settings.show_loader -%}{% render 'volt-loader' %}{%- endif -%}

    <a class="skip-link" href="#main-content">{{ 'general.skip_to_content' | t: default: 'Skip to content' }}</a>

    {%- if settings.use_scroll_smoother -%}<div id="smooth-wrapper"><div id="smooth-content">{%- endif -%}

    {% sections 'header-group' %}

    <main id="main-content">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.use_scroll_smoother -%}</div></div>{%- endif -%}

    {% render 'quick-view' %}
    {% render 'recently-viewed-tracker' %}
    {%- if template.name == 'index' and settings.sticky_cta_enable -%}{% render 'sticky-cta' %}{%- endif -%}

    {%- if settings.use_gsap != false -%}
      {%- comment -%} GSAP 3.13 — standard (free) license incl. all plugins. Loaded from CDN by design choice (off the Theme-Store remote-asset path). {%- endcomment -%}
      {%- comment -%} CDN GSAP + engine deferred & gated by use_gsap; both checks suppressed by the deliberate CDN choice. {%- endcomment -%}
      {%- # theme-check-disable RemoteAsset -%}
      {%- # theme-check-disable AssetSizeJavaScript -%}
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/gsap.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/ScrollTrigger.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/SplitText.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/DrawSVGPlugin.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/MorphSVGPlugin.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/Flip.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/Draggable.min.js" defer></script>
      <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/InertiaPlugin.min.js" defer></script>
      {%- if settings.use_scroll_smoother -%}
        <script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/ScrollSmoother.min.js" defer></script>
      {%- endif -%}
      {%- if settings.smooth_scroll -%}
        <script src="{{ 'lenis.min.js' | asset_url }}" defer></script>
        <script src="{{ 'volt-scroll.js' | asset_url }}" defer></script>
      {%- endif -%}
      <script src="{{ 'volt-animations.js' | asset_url }}" defer></script>
      {%- # theme-check-enable AssetSizeJavaScript -%}
      {%- # theme-check-enable RemoteAsset -%}
    {%- endif -%}
  </body>
</html>
