{% doc %}
  Renders a VOLT product card with per-template behaviour (standard / membership / bundle).
  @param {product} card_product - The product to render. If blank, an onboarding placeholder is shown.
  @example
  {% render 'product-card', card_product: product %}
{% enddoc %}
{%- liquid
  assign p = card_product
  assign show_member = settings.show_member_price
-%}
{%- if p == blank -%}
  <div class="volt-card volt-card--placeholder" data-stagger-item>
    <div class="volt-card__media"><div class="volt-card__imglink">{{ 'product-1' | placeholder_svg_tag: 'volt-card__ph' }}</div></div>
    <div class="volt-card__body">
      <span class="volt-card__cat">Category</span>
      <span class="volt-card__title">Product title</span>
      <div class="volt-card__price"><span class="volt-card__amount">$00</span></div>
    </div>
  </div>
{%- else -%}
  {%- liquid
    assign tpl = p.template_suffix
    assign v = p.selected_or_first_available_variant
    assign badge = ''
    assign cat = ''
    for tag in p.tags
      if tag contains 'badge:' and badge == ''
        assign badge = tag | remove: 'badge:' | upcase
      endif
      if tag contains 'cat:' and cat == ''
        assign cat = tag | remove: 'cat:' | capitalize
      endif
    endfor
  -%}
  <div class="volt-card volt-card--{{ tpl | default: 'standard' }}" data-stagger-item>
    <div class="volt-card__media">
      <a href="{{ p.url }}" class="volt-card__imglink">
        {%- if p.featured_image -%}
          {{ p.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 400, 600', sizes: '(max-width: 860px) 50vw, 25vw', class: 'volt-card__img', alt: p.featured_image.alt | default: p.title | escape }}
          {%- if settings.hover_swap and p.images[1] -%}{{ p.images[1] | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 400, 600', class: 'volt-card__img volt-card__img--2', alt: '' }}{%- endif -%}
        {%- else -%}{{ 'product-1' | placeholder_svg_tag: 'volt-card__ph' }}{%- endif -%}
      </a>

      <div class="volt-card__badges">
        {%- if tpl == 'membership' -%}
          <span class="volt-card__badge volt-card__badge--acid">{{ 'products.membership' | t: default: 'Membership' }}</span>
        {%- elsif tpl == 'bundle' -%}
          <span class="volt-card__badge volt-card__badge--acid">{{ 'products.bundle' | t: default: 'Bundle' }}</span>
        {%- elsif p.available == false -%}
          <span class="volt-card__badge volt-card__badge--ink">{{ 'products.sold_out' | t: default: 'Sold out' }}</span>
        {%- elsif badge != blank -%}
          <span class="volt-card__badge volt-card__badge--ink">{{ badge }}</span>
        {%- endif -%}
        {%- if p.available and v.inventory_management != blank and v.inventory_quantity > 0 and v.inventory_quantity < settings.stock_threshold -%}
          <span class="volt-card__badge volt-card__badge--danger">{{ 'products.only_left' | t: count: v.inventory_quantity, default: 'Only X left' }}</span>
        {%- endif -%}
      </div>

      {%- if show_member and p.compare_at_price > p.price -%}
        {%- assign savepct = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
        {%- assign member_lbl = 'products.member' | t: default: 'Member' -%}
        <span class="volt-card__member">{{ member_lbl | upcase }} −{{ savepct }}%</span>
      {%- endif -%}

      {%- if settings.quick_view and tpl == blank -%}
        <button type="button" class="volt-card__qv" data-quick-view data-handle="{{ p.handle }}" data-magnetic data-magnetic-strength="0.2">{{ 'products.quick_view' | t: default: 'Quick view' }}</button>
      {%- endif -%}

      {%- if settings.quick_buy and p.available and tpl == blank -%}
        {%- form 'product', p, class: 'volt-card__qa' -%}
          <input type="hidden" name="id" value="{{ v.id }}">
          <button type="submit" name="add" class="volt-card__qabtn">{{ 'products.quick_add' | t: default: '+ Quick Add' }}</button>
        {%- endform -%}
      {%- endif -%}
    </div>

    <div class="volt-card__body">
      {%- if cat != blank -%}<span class="volt-card__cat">{{ cat }}</span>{%- endif -%}
      <a href="{{ p.url }}" class="volt-card__title">{{ p.title }}</a>
      {% render 'product-rating', product: p %}

      {%- liquid
        assign color_opt = p.options_with_values | where: 'name', 'Color' | first
        unless color_opt
          assign color_opt = p.options_with_values | where: 'name', 'Colour' | first
        endunless
      -%}
      {%- if color_opt and color_opt.values.size > 1 -%}
        <div class="volt-card__swatches">
          {%- for val in color_opt.values limit: 5 -%}
            {%- assign vimg = '' -%}
            {%- for variant in p.variants -%}
              {%- if variant.options contains val and variant.featured_image -%}{%- assign vimg = variant.featured_image | image_url: width: 600 -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
            <button type="button" class="volt-card__swatch" aria-label="{{ val | escape }}" title="{{ val | escape }}"{% if vimg != blank %} data-swatch-img="{{ vimg }}"{% endif %} style="background-color: {{ val | handleize }};"></button>
          {%- endfor -%}
          {%- if color_opt.values.size > 5 -%}<span class="volt-card__swatchmore">+{{ color_opt.values.size | minus: 5 }}</span>{%- endif -%}
        </div>
      {%- endif -%}

      {%- if tpl == 'membership' -%}
        <div class="volt-card__price">
          <span class="volt-card__amount">{{ 'products.from' | t: default: 'from' }} {{ p.price | money }}</span><span class="volt-card__permo">{{ 'products.per_mo' | t: default: '/mo' }}</span>
        </div>
        <a href="{{ p.url }}" class="volt-card__tplcta">{{ 'products.join_now' | t: default: 'Join now' }} &rarr;</a>
      {%- elsif tpl == 'bundle' -%}
        <div class="volt-card__price"><span class="volt-card__amount">{{ p.price | money }}</span>{%- if p.compare_at_price > p.price -%}<span class="volt-card__compare">{{ p.compare_at_price | money }}</span>{%- endif -%}</div>
        <a href="{{ p.url }}" class="volt-card__tplcta">{{ 'products.get_bundle' | t: default: 'Get the bundle' }} &rarr;</a>
      {%- else -%}
        <div class="volt-card__price">
          <span class="volt-card__amount">{{ p.price | money }}</span>
          {%- if p.compare_at_price > p.price -%}<span class="volt-card__compare">{{ p.compare_at_price | money }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .volt-card { background: var(--color-bg); display: flex; flex-direction: column; }
  .volt-card__media { position: relative; aspect-ratio: 1 / 1; overflow: hidden; background: var(--color-surface); }
  .volt-card__imglink { position: absolute; inset: 0; display: block; }
  .volt-card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
  .volt-card__img--2 { opacity: 0; transition: opacity .35s var(--ease); }
  .volt-card:hover .volt-card__img { transform: scale(1.04); }
  .volt-card:hover .volt-card__img--2 { opacity: 1; }
  .volt-card__ph { position: absolute; inset: 0; width: 100%; height: 100%; }
  .volt-card__badges { position: absolute; top: 0; left: 0; display: flex; flex-direction: column; z-index: 2; }
  .volt-card__badge { font-family: var(--font-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; padding: 5px 9px; }
  .volt-card__badge--ink { background: var(--color-ink); color: var(--color-bg); }
  .volt-card__badge--acid { background: var(--color-acid); color: var(--color-ink); }
  .volt-card__badge--danger { background: var(--color-danger); color: #fff; }
  .volt-card__member { position: absolute; top: 0; right: 0; z-index: 2; font-family: var(--font-mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; background: var(--color-acid); color: var(--color-ink); padding: 5px 9px; }
  .volt-card__qv { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%) scale(.96); z-index: 3; opacity: 0; background: var(--color-bg); color: var(--color-ink); border: 1px solid var(--color-ink); font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; padding: 10px 16px; cursor: pointer; transition: opacity .3s var(--ease), background .2s var(--ease), color .2s var(--ease); }
  .volt-card:hover .volt-card__qv, .volt-card:focus-within .volt-card__qv { opacity: 1; }
  .volt-card__qv:hover { background: var(--color-acid); }
  @media (hover: none) { .volt-card__qv { display: none; } }
  .volt-card__qa { position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; transform: translateY(101%); transition: transform .35s var(--ease); }
  .volt-card:hover .volt-card__qa, .volt-card:focus-within .volt-card__qa { transform: translateY(0); }
  .volt-card__qabtn { width: 100%; border: none; background: var(--color-ink); color: var(--color-bg); font-family: var(--font-body); font-weight: 500; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; padding: 13px; cursor: pointer; }
  .volt-card__qabtn:hover { background: var(--color-acid); color: var(--color-ink); }
  .volt-card__body { padding: 16px 16px 18px; display: flex; flex-direction: column; gap: 9px; flex: 1; }
  .volt-card__cat { font-family: var(--font-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  .volt-card__title { font-family: var(--font-display); font-weight: 700; font-size: 16px; line-height: 1.1; color: var(--color-ink); text-decoration: none; }
  .volt-card__title:hover { color: var(--color-mid); }
  .volt-card__specs { font-family: var(--font-mono); font-size: 10px; letter-spacing: .04em; color: var(--color-mid); margin-top: auto; }
  .volt-card__swatches { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; margin-top: 2px; }
  .volt-card__swatch { width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid var(--color-border); background-size: cover; background-position: center; padding: 0; cursor: pointer; transition: border-color .2s var(--ease), transform .2s var(--ease); }
  .volt-card__swatch:hover, .volt-card__swatch.is-active { border-color: var(--color-ink); transform: scale(1.15); }
  .volt-card__swatchmore { font-family: var(--font-mono); font-size: 9px; color: var(--color-mid); }
  .volt-card__price { display: flex; align-items: baseline; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
  .volt-card__amount { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: var(--color-ink); }
  .volt-card__permo { font-family: var(--font-mono); font-size: 11px; color: var(--color-mid); }
  .volt-card__compare { font-family: var(--font-mono); font-size: 12px; color: var(--color-mid); text-decoration: line-through; }
  .volt-card__mp { font-family: var(--font-mono); font-size: 11px; color: var(--color-ink); background: var(--color-acid); padding: 2px 6px; margin-left: auto; }
  .volt-card__tplcta { font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border-bottom: 2px solid var(--color-acid); padding-bottom: 3px; align-self: flex-start; margin-top: 4px; }
  .volt-card__tplcta:hover { color: var(--color-mid); }
{% endstylesheet %}
