{% comment %}
  This section is used in the password template to render landing page shown
  when password protection is applied to a store.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<h1>{{ 'password.title' | t }}</h1>

{% if shop.password_message %}
  <p>{{ shop.password_message }}</p>
{% endif %}

{% form 'storefront_password' %}
  {% if form.errors %}
    {{ form.errors | default_errors }}
  {% endif %}

  <label for="password-input">
    {{ 'password.password' | t }}
  </label>

  <input type="password" name="password" id="password-input">

  <button type="submit">
    {{ 'password.enter' | t }}
  </button>
{% endform %}

{% stylesheet %}
  label[for="password-input"] {
    transition: color var(--dur-fast) var(--ease);
  }
  label[for="password-input"]:hover {
    color: var(--color-mid);
    transition-delay: .03s;
  }
  form[action*="password"] button[type="submit"] {
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease);
  }
  form[action*="password"] button[type="submit"]:hover,
  form[action*="password"] button[type="submit"]:focus-visible {
    background: var(--color-ink-06);
    transition-delay: .03s;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
