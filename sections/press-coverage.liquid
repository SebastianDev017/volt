{% render 'section-style', section: section %}
{%- liquid
  assign layout = section.settings.layout | default: 'grid'
  assign grayscale = 'false'
  if section.settings.grayscale
    assign grayscale = 'true'
  endif
-%}
<section class="press" data-grayscale="{{ grayscale }}" data-animate>
  <div class="press__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="press__head">
        {%- if section.settings.eyebrow != blank -%}<div class="press__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="press__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if layout == 'marquee' -%}
      <div class="press__marquee">
        <div class="press__track">
          {%- for x in (1..2) -%}
            <div class="press__set"{% if x == 2 %} aria-hidden="true"{% endif %}>
              {%- for block in section.blocks -%}
                {%- liquid
                  assign has_url = false
                  if block.settings.url != blank
                    assign has_url = true
                  endif
                -%}
                <div class="press__item" {{ block.shopify_attributes }}>
                  {%- if has_url -%}<a class="press__link" href="{{ block.settings.url }}"{% if block.settings.publication != blank %} aria-label="{{ block.settings.publication | escape }}"{% endif %}>{%- endif -%}
                    {%- if block.settings.logo != blank -%}
                      {{ block.settings.logo | image_url: width: 300 | image_tag: loading: 'lazy', widths: '120, 200, 300', class: 'press__logo', alt: block.settings.publication | escape }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'press__logo' }}
                    {%- endif -%}
                  {%- if has_url -%}</a>{%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="press__grid" data-stagger-group data-stagger-dir="fade">
        {%- for block in section.blocks -%}
          {%- liquid
            assign has_url = false
            if block.settings.url != blank
              assign has_url = true
            endif
          -%}
          <div class="press__item" data-stagger-item {{ block.shopify_attributes }}>
            {%- if has_url -%}<a class="press__link" href="{{ block.settings.url }}"{% if block.settings.publication != blank %} aria-label="{{ block.settings.publication | escape }}"{% endif %}>{%- endif -%}
              {%- if block.settings.logo != blank -%}
                {{ block.settings.logo | image_url: width: 300 | image_tag: loading: 'lazy', widths: '120, 200, 300', class: 'press__logo', alt: block.settings.publication | escape }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'press__logo' }}
              {%- endif -%}
            {%- if has_url -%}</a>{%- endif -%}
            {%- if block.settings.quote != blank -%}<p class="press__quote">{{ block.settings.quote }}</p>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .press { background: var(--color-bg); border-top: 1px solid var(--color-border); }
  .press__inner { max-width: var(--page-width); margin-inline: auto; padding: calc(clamp(48px, 7vw, 84px) + 20px) 28px; }
  .press__head { text-align: center; margin-bottom: clamp(28px, 4vw, 48px); }
  .press__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  .press__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(30px, 3.22vw, 48px) * var(--section-heading-scale, 1)); line-height: 1.04; letter-spacing: -.01em; margin: 14px 0 0; color: var(--color-ink); }

  .press__grid { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: clamp(28px, 5vw, 64px); }
  .press__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; }
  .press__link { display: inline-flex; align-items: center; justify-content: center; }
  .press__logo { width: auto; max-height: 44px; max-width: 180px; object-fit: contain; transition: filter var(--dur-med) var(--ease), opacity var(--dur-med) var(--ease); }
  .press__quote { max-width: 220px; font-family: var(--font-body); font-size: 12px; line-height: 1.5; color: var(--color-mid); margin: 0; }

  .press[data-grayscale="true"] .press__logo { filter: grayscale(1); opacity: .5; }
  .press[data-grayscale="true"] .press__logo:hover { filter: none; opacity: 1; transition-delay: .08s; }
  .press[data-grayscale="false"] .press__link:hover .press__logo,
  .press[data-grayscale="false"] .press__link:focus-visible .press__logo { opacity: .6; transition-delay: .08s; }

  .press__marquee { overflow: hidden; width: 100%; }
  .press__track { display: flex; width: max-content; animation: press-marquee 38s linear infinite; }
  .press__marquee:hover .press__track { animation-play-state: paused; transition-delay: .08s; }
  .press__set { display: flex; align-items: center; gap: clamp(28px, 5vw, 64px); padding-right: clamp(28px, 5vw, 64px); }
  .press__set .press__item { flex-direction: row; }

  @keyframes press-marquee { to { transform: translateX(-50%); } }

  @media (max-width: 480px) { .press__grid { gap: 28px; } .press__logo { max-height: 36px; max-width: 140px; } }

  @media (prefers-reduced-motion: reduce) { .press__track { animation: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.press_coverage.name",
  "tag": "section",
  "blocks": [
    {
      "type": "press_item",
      "name": "t:sections.press_coverage.blocks.press_item.name",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "t:sections.press_coverage.blocks.press_item.logo" },
        { "type": "text", "id": "publication", "label": "t:sections.press_coverage.blocks.press_item.publication", "default": "Publication" },
        { "type": "textarea", "id": "quote", "label": "t:sections.press_coverage.blocks.press_item.quote", "info": "t:sections.press_coverage.blocks.press_item.quote_info" },
        { "type": "url", "id": "url", "label": "t:sections.press_coverage.blocks.press_item.url" }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "text", "id": "eyebrow", "label": "t:sections.press_coverage.eyebrow", "default": "// As featured in" },
    { "type": "text", "id": "heading", "label": "t:sections.press_coverage.heading" },
    { "type": "select", "id": "layout", "label": "t:sections.press_coverage.layout", "default": "grid", "options": [
      { "value": "grid", "label": "t:sections.press_coverage.layout_grid" },
      { "value": "marquee", "label": "t:sections.press_coverage.layout_marquee" }
    ] },
    { "type": "checkbox", "id": "grayscale", "label": "t:sections.press_coverage.grayscale", "info": "t:sections.press_coverage.grayscale_info", "default": true }
  ],
  "presets": [
    {
      "name": "t:sections.press_coverage.name",
      "blocks": [
        { "type": "press_item", "settings": { "publication": "Men's Health" } },
        { "type": "press_item", "settings": { "publication": "Runner's World" } },
        { "type": "press_item", "settings": { "publication": "GQ" } },
        { "type": "press_item", "settings": { "publication": "Wired" } },
        { "type": "press_item", "settings": { "publication": "Outside" } }
      ]
    }
  ]
}
{% endschema %}
