{% render 'section-style', section: section %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'default'
-%}
<div class="volt-statement volt-statement--{{ scheme }}" data-animate>
  <div class="section-inner volt-statement__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow volt-statement__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="h1 volt-statement__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.attribution != blank -%}
      <p class="volt-statement__attr muted">{{ section.settings.attribution }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .volt-statement { padding-block: var(--section-space); text-align: center; }
  .volt-statement--surface { background: var(--color-surface); }
  .volt-statement--ink { background: var(--color-ink); color: var(--color-bg); }
  .volt-statement__inner { max-width: 900px; }
  .volt-statement__eyebrow { margin-bottom: 20px; }
  .volt-statement__heading { margin-inline: auto; }
  .volt-statement__heading em { color: var(--color-acid); font-style: normal; }
  .volt-statement__attr { margin-top: 24px; font-style: italic; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.editorial_statement.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.editorial_statement.eyebrow",
      "default": "Our philosophy"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.editorial_statement.heading",
      "default": "Your body is the <em>data</em>. We help you read it."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "t:sections.editorial_statement.attribution"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.editorial_statement.color_scheme",
      "options": [
        { "value": "default", "label": "t:sections.editorial_statement.scheme_default" },
        { "value": "surface", "label": "t:sections.editorial_statement.scheme_surface" },
        { "value": "ink", "label": "t:sections.editorial_statement.scheme_ink" }
      ],
      "default": "default"
    }
  ],
  "presets": [
    { "name": "t:sections.editorial_statement.name" }
  ]
}
{% endschema %}
