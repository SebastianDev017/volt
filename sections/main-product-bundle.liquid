{%- liquid
  assign p = product
  assign bundle_info = section.blocks | where: 'type', 'bundle_info' | first
  assign discount = bundle_info.settings.discount_percent | default: 20
  assign label = bundle_info.settings.badge_label | default: 'Bundle Deal'
  assign bundle_items = section.blocks | where: 'type', 'bundle_item'
  assign individual = 0
  assign has_steps = false
  for block in bundle_items
    assign ip = block.settings.product
    if ip != blank and block.settings.optional != true
      assign line_total = ip.price | times: block.settings.quantity
      assign individual = individual | plus: line_total
    endif
    assign bstep = block.settings.step | default: '1'
    if bstep != '1'
      assign has_steps = true
    endif
  endfor
  assign savings = individual | minus: p.price
-%}
<section class="volt-bundle" data-animate>
  <div class="volt-bundle__inner">
    <div class="volt-bundle__head">
      <span class="volt-bundle__badge">{{ label }}</span>
      <h1 class="volt-bundle__title">{{ p.title }}</h1>
      {%- if bundle_info.settings.savings_label != blank -%}
        <div class="volt-bundle__savecallout">{{ bundle_info.settings.savings_label }}</div>
      {%- elsif discount != blank and discount > 0 -%}
        <div class="volt-bundle__savecallout">Save {{ discount }}% vs buying individually</div>
      {%- elsif savings > 0 -%}
        <div class="volt-bundle__savecallout">Save {{ savings | money }} vs buying individually</div>
      {%- endif -%}
      {%- if section.settings.social_proof != blank -%}<p class="volt-bundle__social">{{ section.settings.social_proof }}</p>{%- endif -%}
    </div>

    {%- if bundle_items.size > 0 -%}
      {%- capture step_labels -%}{{ section.settings.step1_label | default: 'The base' }}|{{ section.settings.step2_label | default: 'Choose your flavor' }}|{{ section.settings.step3_label | default: 'Goal add-ons' }}{%- endcapture -%}
      {%- assign step_label_arr = step_labels | split: '|' -%}
      <form data-bundle-form data-bundle-handle="{{ p.handle }}" data-bundle-price="{{ p.price }}" class="volt-bundle__form">
        {%- if has_steps -%}
          {%- comment -%} Guided 3-step builder (Gainful build-your-own flow) {%- endcomment -%}
          <div class="volt-bundle__steps">
            {%- for snum in (1..3) -%}
              {%- assign s = snum | append: '' -%}
              {%- assign step_count = 0 -%}
              {%- for block in bundle_items -%}
                {%- assign bstep = block.settings.step | default: '1' -%}
                {%- if bstep == s and block.settings.product != blank -%}{%- assign step_count = step_count | plus: 1 -%}{%- endif -%}
              {%- endfor -%}
              {%- if step_count > 0 -%}
                <div class="volt-bundle__step">
                  <div class="volt-bundle__stephead">
                    <span class="volt-bundle__stepnum">0{{ snum }}</span>
                    <span class="volt-bundle__steplabel">{{ step_label_arr[forloop.index0] }}</span>
                  </div>
                  <div class="volt-bundle__stepitems">
                    {%- for block in bundle_items -%}
                      {%- assign bstep = block.settings.step | default: '1' -%}
                      {%- assign ip = block.settings.product -%}
                      {%- if bstep == s and ip != blank -%}
                        {% render 'bundle-item', block: block, ip: ip, addon_label: section.settings.addon_label %}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="volt-bundle__grid">
            {%- for block in bundle_items -%}
              {%- assign ip = block.settings.product -%}
              {%- if ip != blank -%}
                {% render 'bundle-item', block: block, ip: ip, addon_label: section.settings.addon_label %}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="volt-bundle__pricing">
          <div class="volt-bundle__pricecol">
            {%- if individual > 0 -%}<div class="volt-bundle__indiv">Individual value <s data-bundle-indiv>{{ individual | money }}</s></div>{%- endif -%}
            <div class="volt-bundle__price">{{ p.price | money }}</div>
            <span class="volt-bundle__savepill" data-bundle-savepill{% unless savings > 0 %} hidden{% endunless %}>You save {% if discount != blank and discount > 0 %}{{ discount }}% — {% endif %}{{ savings | money }}</span>
          </div>
          <button type="submit" data-bundle-submit class="volt-bundle__add">Add protocol to bag</button>
        </div>

        <div class="volt-bundle__callouts">
          <span><i>&#9670;</i> Free shipping</span><span><i>&#9670;</i> Ships in 2&ndash;3 days</span><span><i>&#9670;</i> 30-day guarantee</span>
        </div>
      </form>
    {%- else -%}
      <p class="volt-bundle__empty">Add <strong>Bundle item</strong> blocks in the theme editor to populate this bundle.</p>
    {%- endif -%}

    {%- assign benefits = section.blocks | where: 'type', 'bundle_benefit' -%}
    {%- if benefits.size > 0 -%}
      <div class="volt-bundle__why">
        <div class="volt-bundle__whyeyebrow">// Why this bundle</div>
        <div class="volt-bundle__whygrid">
          {%- for block in benefits -%}
            <div class="volt-bundle__benefit" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}<span class="volt-bundle__benefiticon">{{ block.settings.icon }}</span>{%- endif -%}
              <h3 class="volt-bundle__benefitheading">{{ block.settings.heading }}</h3>
              {%- if block.settings.description != blank -%}<p class="volt-bundle__benefitdesc">{{ block.settings.description }}</p>{%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .volt-bundle__inner { max-width: var(--page-width); margin-inline: auto; padding: 40px 28px 70px; }
  .volt-bundle__head { text-align: center; max-width: 720px; margin: 0 auto 40px; }
  .volt-bundle__badge { display: inline-block; font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; background: var(--color-acid); color: var(--color-ink); padding: 5px 10px; }
  .volt-bundle__title { font-family: var(--font-display); font-weight: 800; font-size: clamp(32px, 4vw, 52px); line-height: 1.02; letter-spacing: -.01em; margin: 16px 0 0; }
  .volt-bundle__savecallout { font-family: var(--font-mono); font-size: 13px; letter-spacing: .04em; color: var(--color-acid); margin-top: 14px; }
  .volt-bundle__social { font-family: var(--font-display); font-style: italic; color: var(--color-mid); margin: 8px 0 0; }
  .volt-bundle__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }

  /* ── Guided 3-step builder (Gainful flow; arrow chain like how-it-works) ── */
  .volt-bundle__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(16px, 2.5vw, 32px); align-items: start; }
  .volt-bundle__step { position: relative; }
  .volt-bundle__stephead { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .volt-bundle__stepnum { display: inline-grid; place-items: center; width: 30px; height: 30px; background: var(--color-ink); color: var(--color-acid); font-family: var(--font-mono); font-size: 11px; }
  .volt-bundle__steplabel { font-family: var(--font-display); font-weight: 800; font-size: 16px; }
  .volt-bundle__step:not(:last-child) .volt-bundle__stephead::after { content: "→"; margin-left: auto; color: var(--color-mid); font-size: 18px; }
  .volt-bundle__stepitems { display: flex; flex-direction: column; gap: 14px; }
  .volt-bundle__stepitems .volt-bundle__item { border: 1px solid var(--color-border); }
  .volt-bundle__included--opt { background: var(--color-ink); color: var(--color-acid); }
  .volt-bundle__item--optional { opacity: .82; transition: opacity var(--dur-fast) var(--ease); }
  .volt-bundle__item--optional:has([data-bundle-toggle]:checked) { opacity: 1; outline: 2px solid var(--color-acid); outline-offset: -2px; }
  .volt-bundle__toggle { display: flex; align-items: center; gap: 9px; cursor: pointer; margin-top: auto; font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em; }
  .volt-bundle__toggle input { width: 16px; height: 16px; accent-color: var(--color-acid); cursor: pointer; }
  .volt-bundle__item { background: var(--color-bg); display: flex; flex-direction: column; }
  .volt-bundle__itemimg { position: relative; display: block; aspect-ratio: 1/1; background: var(--color-surface); overflow: hidden; }
  .volt-bundle__itemimg img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-fast) var(--ease); }
  .volt-bundle__itemimg:hover img, .volt-bundle__itemimg:focus-visible img { transform: scale(1.04); transition-delay: .08s; }
  .volt-bundle__included { position: absolute; top: 0; left: 0; font-family: var(--font-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; background: var(--color-success); color: #06210F; padding: 5px 9px; }
  .volt-bundle__itembody { padding: 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .volt-bundle__itemname { font-family: var(--font-display); font-weight: 700; font-size: 16px; }
  .volt-bundle__choose { font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em; color: var(--color-mid); }
  .volt-bundle__select { width: 100%; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 0; padding: 10px 12px; font-family: var(--font-body); font-size: 13px; }
  .volt-bundle__itemprice { margin-top: auto; font-family: var(--font-mono); font-size: 12px; }
  .volt-bundle__itemprice s { color: var(--color-mid); }
  .volt-bundle__itemprice span { display: block; color: var(--color-acid); font-style: italic; margin-top: 4px; }
  .volt-bundle__pricing { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; border: 1px solid var(--color-border); border-top: 0; padding: 24px 28px; }
  .volt-bundle__indiv { font-family: var(--font-mono); font-size: 12px; color: var(--color-mid); }
  .volt-bundle__indiv s { margin-left: 6px; }
  .volt-bundle__price { font-family: var(--font-display); font-weight: 800; font-size: clamp(36px, 4vw, 56px); line-height: 1; margin: 4px 0; }
  .volt-bundle__savepill { display: inline-block; font-family: var(--font-mono); font-size: 12px; background: var(--color-acid); color: var(--color-ink); padding: 6px 12px; }
  .volt-bundle__add { background: var(--color-acid); border: 0; color: var(--color-ink); font-family: var(--font-body); font-weight: 500; font-size: 14px; letter-spacing: .05em; text-transform: uppercase; padding: 18px 32px; cursor: pointer; transition: filter var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease); }
  .volt-bundle__add:hover, .volt-bundle__add:focus-visible { filter: brightness(1.05); box-shadow: 0 0 0 4px var(--color-acid-10); transition-delay: .03s; }
  .volt-bundle__callouts { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin-top: 18px; font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-mid); }
  .volt-bundle__callouts i { color: var(--color-acid); font-style: normal; }
  .volt-bundle__empty { text-align: center; color: var(--color-mid); padding: 40px 0; }
  .volt-bundle__why { margin-top: 64px; }
  .volt-bundle__whyeyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); margin-bottom: 24px; }
  .volt-bundle__whygrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .volt-bundle__benefiticon { font-size: 26px; }
  .volt-bundle__benefitheading { font-family: var(--font-display); font-weight: 700; font-size: 18px; margin: 12px 0 6px; }
  .volt-bundle__benefitdesc { font-size: 14px; line-height: 1.6; color: var(--color-mid); margin: 0; }
  @media (max-width: 860px) { .volt-bundle__grid, .volt-bundle__whygrid, .volt-bundle__steps { grid-template-columns: 1fr; } .volt-bundle__pricing { flex-direction: column; align-items: stretch; } .volt-bundle__add { width: 100%; } .volt-bundle__step:not(:last-child) .volt-bundle__stephead::after { content: "↓"; } }
{% endstylesheet %}

<script>
  (function () {
    function money(cents) {
      try { return new Intl.NumberFormat(document.documentElement.lang || 'en', { style: 'currency', currency: (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD' }).format(cents / 100); }
      catch (e) { return '$' + (cents / 100).toFixed(2); }
    }
    function recalc(form) {
      var total = 0;
      form.querySelectorAll('[data-bundle-item]').forEach(function (el) {
        if (el.disabled || !el.value) return;
        total += parseInt(el.dataset.linePrice || '0', 10);
      });
      var indiv = form.querySelector('[data-bundle-indiv]');
      if (indiv && total > 0) indiv.textContent = money(total);
      var pill = form.querySelector('[data-bundle-savepill]');
      if (pill) {
        var savings = total - parseInt(form.dataset.bundlePrice || '0', 10);
        if (savings > 0) { pill.hidden = false; pill.textContent = 'You save ' + money(savings); }
        else { pill.hidden = true; }
      }
    }
    function init(form) {
      var button = form.querySelector('[data-bundle-submit]');
      // Step builder: flavor/variant selects update the hidden line input; optional
      // add-on toggles enable/disable it. Both re-run the live totals.
      form.addEventListener('change', function (e) {
        var sel = e.target.closest ? e.target.closest('[data-bundle-variant]') : null;
        if (sel) {
          var item = sel.closest('.volt-bundle__item');
          var input = item && item.querySelector('[data-bundle-item]');
          var opt = sel.options[sel.selectedIndex];
          if (input && opt) { input.value = opt.value; input.dataset.linePrice = opt.dataset.linePrice || input.dataset.linePrice; }
          recalc(form);
          return;
        }
        var tog = e.target.closest ? e.target.closest('[data-bundle-toggle]') : null;
        if (tog) {
          var titem = tog.closest('.volt-bundle__item');
          var tinput = titem && titem.querySelector('[data-bundle-item]');
          if (tinput) tinput.disabled = !tog.checked;
          recalc(form);
        }
      });
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!button) return;
        button.disabled = true; var original = button.textContent; button.textContent = 'Adding...';
        var items = [];
        form.querySelectorAll('[data-bundle-item]').forEach(function (el) {
          if (!el.value || el.disabled) return;
          items.push({ id: parseInt(el.value, 10), quantity: parseInt(el.dataset.quantity || '1', 10), properties: { _bundle: form.dataset.bundleHandle, _bundle_item: 'true' } });
        });
        if (!items.length) { button.disabled = false; button.textContent = original; return; }
        fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items }) })
          .then(function (r) { if (!r.ok) throw new Error('add failed'); return r.json(); })
          .then(function () { return fetch('/cart.js'); })
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            document.querySelectorAll('[data-cart-count]').forEach(function (n) { n.textContent = cart.item_count; });
            document.dispatchEvent(new CustomEvent('volt:cart:open'));
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: { item_count: cart.item_count } }));
            button.textContent = 'Added to bag ✓';
            setTimeout(function () { button.disabled = false; button.textContent = original; }, 2500);
          })
          .catch(function () { button.textContent = 'Try again'; setTimeout(function () { button.disabled = false; button.textContent = original; }, 2500); });
      });
    }
    document.querySelectorAll('[data-bundle-form]').forEach(init);
  })();
</script>

{% schema %}
{
  "name": "t:sections.main_product_bundle.name",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Build the bundle by adding Bundle item blocks (one product each), then add a single Bundle info block to set the discount, savings label, and header badge. Give items a Step (base / flavor / add-on) to switch to the guided 3-step builder." },
    { "type": "text", "id": "social_proof", "label": "t:sections.main_product_bundle.social_proof", "default": "Most popular protocol" },
    { "type": "header", "content": "t:sections.main_product_bundle.stepper_header" },
    { "type": "text", "id": "step1_label", "label": "t:sections.main_product_bundle.step1_label", "default": "The base" },
    { "type": "text", "id": "step2_label", "label": "t:sections.main_product_bundle.step2_label", "default": "Choose your flavor" },
    { "type": "text", "id": "step3_label", "label": "t:sections.main_product_bundle.step3_label", "default": "Goal add-ons" },
    { "type": "text", "id": "addon_label", "label": "t:sections.main_product_bundle.addon_label", "default": "Add to protocol" }
  ],
  "blocks": [
    {
      "type": "bundle_item",
      "name": "t:sections.main_product_bundle.blocks.bundle_item.name",
      "settings": [
        { "type": "product", "id": "product", "label": "t:sections.main_product_bundle.blocks.bundle_item.product" },
        { "type": "range", "id": "quantity", "min": 1, "max": 10, "step": 1, "default": 1, "label": "t:sections.main_product_bundle.blocks.bundle_item.quantity" },
        { "type": "select", "id": "step", "label": "t:sections.main_product_bundle.blocks.bundle_item.step", "default": "1", "options": [
          { "value": "1", "label": "t:sections.main_product_bundle.blocks.bundle_item.step_base" },
          { "value": "2", "label": "t:sections.main_product_bundle.blocks.bundle_item.step_flavor" },
          { "value": "3", "label": "t:sections.main_product_bundle.blocks.bundle_item.step_addon" }
        ] },
        { "type": "checkbox", "id": "optional", "label": "t:sections.main_product_bundle.blocks.bundle_item.optional", "info": "t:sections.main_product_bundle.blocks.bundle_item.optional_info", "default": false }
      ]
    },
    {
      "type": "bundle_info",
      "name": "t:sections.main_product_bundle.blocks.bundle_info.name",
      "limit": 1,
      "settings": [
        { "type": "range", "id": "discount_percent", "min": 0, "max": 50, "step": 5, "default": 20, "label": "t:sections.main_product_bundle.blocks.bundle_info.discount_percent" },
        { "type": "text", "id": "savings_label", "label": "t:sections.main_product_bundle.blocks.bundle_info.savings_label", "default": "SAVE 20% vs buying individually" },
        { "type": "text", "id": "badge_label", "label": "t:sections.main_product_bundle.blocks.bundle_info.badge_label", "default": "Bundle Deal" }
      ]
    },
    {
      "type": "bundle_benefit",
      "name": "t:sections.main_product_bundle.blocks.benefit.name",
      "settings": [
        { "type": "text", "id": "icon", "label": "t:sections.main_product_bundle.blocks.benefit.icon", "default": "⚡" },
        { "type": "text", "id": "heading", "label": "t:sections.main_product_bundle.blocks.benefit.heading", "default": "Engineered to stack" },
        { "type": "textarea", "id": "description", "label": "t:sections.main_product_bundle.blocks.benefit.description", "default": "Each item is dosed to work with the others — no redundant ingredients, no wasted scoops." }
      ]
    }
  ],
  "presets": [
    { "name": "t:sections.main_product_bundle.name" }
  ]
}
{% endschema %}
