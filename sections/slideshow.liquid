{% render 'section-style', section: section %}
<volt-slideshow class="vss vss--{{ section.settings.height }}" data-autoplay="{{ section.settings.autoplay }}" data-animate>
  <div class="vss__viewport">
    {%- for block in section.blocks -%}
      {%- assign overlay = block.settings.overlay_opacity | times: 1.0 | divided_by: 100.0 -%}
      <div class="vss__slide vss__slide--{{ block.settings.text_align }}{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" {% unless forloop.first %}aria-hidden="true"{% endunless %} {{ block.shopify_attributes }}>
        <div class="vss__media">
          {%- if block.settings.image != blank -%}
            {%- if forloop.first -%}
              {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', widths: '800,1200,1600,2000', class: 'vss__img', alt: block.settings.image.alt | default: block.settings.heading }}
            {%- else -%}
              {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '100vw', widths: '800,1200,1600,2000', class: 'vss__img', alt: block.settings.image.alt | default: block.settings.heading }}
            {%- endif -%}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'vss__img vss__img--placeholder' }}
          {%- endif -%}
        </div>
        <div class="vss__overlay" style="opacity: {{ overlay }}"></div>
        <div class="vss__inner">
          <div class="vss__content">
            {%- if block.settings.eyebrow != blank -%}
              <div class="vss__eyebrow">{{ block.settings.eyebrow }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="vss__title">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="vss__body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <div class="vss__cta">
                <a href="{{ block.settings.cta_url | default: '#' }}" class="btn btn--acid" data-magnetic>{{ block.settings.cta_label }}</a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
    <button class="vss__arrow vss__arrow--prev" type="button" data-vss-prev aria-label="{{ 'sections.slideshow.previous' | t: default: 'Previous slide' }}">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg>
    </button>
    <button class="vss__arrow vss__arrow--next" type="button" data-vss-next aria-label="{{ 'sections.slideshow.next' | t: default: 'Next slide' }}">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="m9 5 7 7-7 7"/></svg>
    </button>
  {%- endif -%}

  {%- if section.settings.show_dots and section.blocks.size > 1 -%}
    <div class="vss__dots" role="tablist">
      {%- for block in section.blocks -%}
        <button class="vss__dot{% if forloop.first %} is-active{% endif %}" type="button" data-vss-dot="{{ forloop.index0 }}" role="tab" aria-label="{{ 'sections.slideshow.go_to' | t: default: 'Go to slide' }} {{ forloop.index }}" {% if forloop.first %}aria-selected="true"{% else %}aria-selected="false"{% endif %}></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</volt-slideshow>

{% stylesheet %}
  .vss { position: relative; display: block; overflow: hidden; background: var(--color-ink); color: var(--color-bg); }
  .vss__viewport { position: relative; width: 100%; height: 100%; }
  .vss--medium .vss__viewport { min-height: 60vh; }
  .vss--large .vss__viewport { min-height: 78vh; }
  .vss--full .vss__viewport { min-height: 100vh; }

  .vss__slide { position: absolute; inset: 0; display: flex; align-items: center; opacity: 0; visibility: hidden; transition: opacity var(--dur-slow) var(--ease), visibility var(--dur-slow) var(--ease); pointer-events: none; }
  .vss__slide.is-active { opacity: 1; visibility: visible; pointer-events: auto; }

  .vss__media { position: absolute; inset: 0; z-index: 0; }
  .vss__img { width: 100%; height: 100%; object-fit: cover; }
  .vss__img--placeholder { background: var(--color-surface); }
  .vss__overlay { position: absolute; inset: 0; z-index: 1; background: var(--color-ink); pointer-events: none; }

  .vss__inner { position: relative; z-index: 2; width: 100%; max-width: var(--page-width); margin-inline: auto; padding: calc(clamp(48px, 8vw, 110px) + 20px) 28px; }
  .vss__content { max-width: 38ch; display: flex; flex-direction: column; align-items: flex-start; }
  .vss__slide--center .vss__inner { display: flex; justify-content: center; text-align: center; }
  .vss__slide--center .vss__content { align-items: center; }

  .vss__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-acid); }
  .vss__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(46px, 6vw, 87px) * var(--section-heading-scale, 1)); line-height: .94; letter-spacing: -.02em; text-transform: uppercase; color: var(--color-bg); margin: 18px 0 0; }
  .vss__body { font-size: 16px; line-height: 1.6; color: rgba(240,238,234,.85); margin: 22px 0 0; }
  .vss__cta { margin-top: 32px; }

  .vss__arrow { position: absolute; top: 50%; z-index: 3; transform: translateY(-50%); width: 52px; height: 52px; display: inline-flex; align-items: center; justify-content: center; background: rgba(13,12,11,.45); color: var(--color-bg); border: 1px solid rgba(240,238,234,.22); transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease); }
  .vss__arrow:hover { background: var(--color-acid); color: var(--color-ink); border-color: var(--color-acid); transition-delay: .03s; }
  .vss__arrow--prev { left: 18px; }
  .vss__arrow--next { right: 18px; }

  .vss__dots { position: absolute; left: 0; right: 0; bottom: 24px; z-index: 3; display: flex; justify-content: center; gap: 10px; }
  .vss__dot { width: 9px; height: 9px; border-radius: 50%; background: rgba(240,238,234,.4); border: 1px solid rgba(240,238,234,.5); transition: background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease); }
  .vss__dot:hover { background: rgba(240,238,234,.75); transition-delay: .06s; }
  .vss__dot.is-active { background: var(--color-acid); border-color: var(--color-acid); transform: scale(1.15); }

  @media (max-width: 860px) {
    .vss--medium .vss__viewport { min-height: 56vh; }
    .vss--large .vss__viewport { min-height: 66vh; }
    .vss--full .vss__viewport { min-height: 88vh; }
    .vss__inner { padding-inline: 24px; }
    .vss__content { max-width: 100%; }
    .vss__arrow { width: 44px; height: 44px; }
    .vss__arrow--prev { left: 12px; }
    .vss__arrow--next { right: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vss__slide { transition: none; }
  }
{% endstylesheet %}

<script>
  if (!customElements.get('volt-slideshow')) {
    customElements.define('volt-slideshow', class extends HTMLElement {
      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.vss__slide'));
        this.dots = Array.from(this.querySelectorAll('[data-vss-dot]'));
        if (this.slides.length < 2) return;
        this.index = 0;
        this.reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        this.delay = (parseInt(this.getAttribute('data-autoplay'), 10) || 0) * 1000;

        const prev = this.querySelector('[data-vss-prev]');
        const next = this.querySelector('[data-vss-next]');
        if (prev) prev.addEventListener('click', () => { this.go(this.index - 1); this.restart(); });
        if (next) next.addEventListener('click', () => { this.go(this.index + 1); this.restart(); });
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            this.go(parseInt(dot.getAttribute('data-vss-dot'), 10));
            this.restart();
          });
        });

        this.addEventListener('mouseenter', () => this.stop());
        this.addEventListener('mouseleave', () => this.start());

        this.start();
      }

      disconnectedCallback() { this.stop(); }

      go(i) {
        const total = this.slides.length;
        this.index = (i + total) % total;
        this.slides.forEach((slide, n) => {
          const active = n === this.index;
          slide.classList.toggle('is-active', active);
          if (active) { slide.removeAttribute('aria-hidden'); }
          else { slide.setAttribute('aria-hidden', 'true'); }
        });
        this.dots.forEach((dot, n) => {
          const active = n === this.index;
          dot.classList.toggle('is-active', active);
          dot.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }

      start() {
        if (this.reduced || this.delay <= 0) return;
        this.stop();
        this.timer = setInterval(() => this.go(this.index + 1), this.delay);
      }

      stop() {
        if (this.timer) { clearInterval(this.timer); this.timer = null; }
      }

      restart() { this.stop(); this.start(); }
    });
  }
</script>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "range", "id": "autoplay", "min": 0, "max": 10, "step": 1, "unit": "s", "label": "t:sections.slideshow.autoplay", "info": "t:sections.slideshow.autoplay_info", "default": 6 },
    { "type": "select", "id": "height", "label": "t:sections.slideshow.height", "default": "large", "options": [
      { "value": "medium", "label": "t:sections.slideshow.height_medium" },
      { "value": "large", "label": "t:sections.slideshow.height_large" },
      { "value": "full", "label": "t:sections.slideshow.height_full" }
    ] },
    { "type": "checkbox", "id": "show_arrows", "label": "t:sections.slideshow.show_arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "t:sections.slideshow.show_dots", "default": true }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.blocks.slide.name",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.slideshow.blocks.slide.image" },
        { "type": "text", "id": "eyebrow", "label": "t:sections.slideshow.blocks.slide.eyebrow" },
        { "type": "text", "id": "heading", "label": "t:sections.slideshow.blocks.slide.heading", "default": "Train without limits" },
        { "type": "textarea", "id": "body", "label": "t:sections.slideshow.blocks.slide.body" },
        { "type": "text", "id": "cta_label", "label": "t:sections.slideshow.blocks.slide.cta_label", "default": "Join now" },
        { "type": "url", "id": "cta_url", "label": "t:sections.slideshow.blocks.slide.cta_url" },
        { "type": "select", "id": "text_align", "label": "t:sections.slideshow.blocks.slide.text_align", "default": "left", "options": [
          { "value": "left", "label": "t:sections.slideshow.blocks.slide.align_left" },
          { "value": "center", "label": "t:sections.slideshow.blocks.slide.align_center" }
        ] },
        { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "t:sections.slideshow.blocks.slide.overlay_opacity", "default": 35 }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.name",
      "blocks": [
        { "type": "slide", "settings": { "eyebrow": "// Performance Membership", "heading": "Train without limits", "body": "Data-driven coaching, recovery tracking, and a community that shows up. Your protocol starts here.", "cta_label": "Join now", "text_align": "left", "overlay_opacity": 35 } },
        { "type": "slide", "settings": { "eyebrow": "// Recovery First", "heading": "Recover like it matters", "body": "Strain, sleep, and HRV in one dashboard. Know exactly when to push and when to rest.", "cta_label": "See the dashboard", "text_align": "left", "overlay_opacity": 45 } }
      ]
    }
  ]
}
{% endschema %}
