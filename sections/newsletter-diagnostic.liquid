{% render 'section-style', section: section %}
{%- liquid
  assign tier_starter = section.settings.tier_starter_handle | default: 'starter'
  assign tier_performance = section.settings.tier_performance_handle | default: 'performance'
  assign tier_elite = section.settings.tier_elite_handle | default: 'elite'
-%}

<div class="volt-diag" data-volt-section="newsletter-diagnostic" data-animate>
  <div class="volt-diag__inner volt-diag__grid">

    {%- comment -%} LEFT — diagnostic quiz {%- endcomment -%}
    <div class="volt-diag__left">
      {%- if section.settings.eyebrow != blank -%}<p class="volt-diag__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2 class="volt-diag__heading" {% render 'anim-attrs', value: section.settings.heading_animation, enabled: section.settings.enable_animations, delay_ms: section.settings.section_delay %}>{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}<p class="volt-diag__body" {% render 'anim-attrs', value: 'fade-up', enabled: section.settings.enable_animations %}>{{ section.settings.body }}</p>{%- endif -%}

      <diagnostic-quiz
        class="volt-quiz"
        data-base="/products/volt-membership-"
        data-tier-starter="{{ tier_starter }}"
        data-tier-performance="{{ tier_performance }}"
        data-tier-elite="{{ tier_elite }}"
      >
        <div class="volt-quiz__bar" aria-hidden="true"><span class="volt-quiz__bar-fill" data-quiz-fill></span></div>
        <p class="volt-quiz__progress"><span data-quiz-step>01</span> / 04</p>

        <form class="volt-quiz__form">
          <fieldset class="volt-quiz__step" data-quiz-fieldset="0" aria-current="step">
            <legend class="volt-quiz__legend">{{ 'sections.newsletter_diagnostic.q1_title' | t: default: 'Primary goal' }}</legend>
            <div class="volt-quiz__options">
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q1_a' | t: default: 'Build strength' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q1_b' | t: default: 'Improve endurance' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q1_c' | t: default: 'Lose fat' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q1_d' | t: default: 'General health' }}</button>
            </div>
          </fieldset>
          <fieldset class="volt-quiz__step" data-quiz-fieldset="1" hidden>
            <legend class="volt-quiz__legend">{{ 'sections.newsletter_diagnostic.q2_title' | t: default: 'Training frequency' }}</legend>
            <div class="volt-quiz__options">
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q2_a' | t: default: '1–2x per week' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q2_b' | t: default: '3–4x per week' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q2_c' | t: default: '5+ per week' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q2_d' | t: default: 'Not training yet' }}</button>
            </div>
          </fieldset>
          <fieldset class="volt-quiz__step" data-quiz-fieldset="2" hidden>
            <legend class="volt-quiz__legend">{{ 'sections.newsletter_diagnostic.q3_title' | t: default: 'Biggest challenge' }}</legend>
            <div class="volt-quiz__options">
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q3_a' | t: default: 'Staying motivated' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q3_b' | t: default: 'Programming' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q3_c' | t: default: 'Nutrition' }}</button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer>{{ 'sections.newsletter_diagnostic.q3_d' | t: default: 'Recovery' }}</button>
            </div>
          </fieldset>
          <fieldset class="volt-quiz__step" data-quiz-fieldset="3" hidden>
            <legend class="volt-quiz__legend">{{ 'sections.newsletter_diagnostic.q4_title' | t: default: 'Membership interest' }}</legend>
            <div class="volt-quiz__options">
              <button type="button" class="volt-quiz__opt" data-quiz-answer data-quiz-tier="starter">{{ 'sections.newsletter_diagnostic.q4_a' | t: default: 'Starter' }}<span class="volt-quiz__price">$29/mo</span></button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer data-quiz-tier="performance">{{ 'sections.newsletter_diagnostic.q4_b' | t: default: 'Performance' }}<span class="volt-quiz__price">$49/mo</span></button>
              <button type="button" class="volt-quiz__opt" data-quiz-answer data-quiz-tier="elite">{{ 'sections.newsletter_diagnostic.q4_c' | t: default: 'Elite' }}<span class="volt-quiz__price">$89/mo</span></button>
            </div>
            <a class="volt-quiz__cta" data-quiz-cta href="/products/volt-membership-performance">{{ 'sections.newsletter_diagnostic.cta' | t: default: 'Start my protocol' }} &rarr;</a>
          </fieldset>
          <div class="volt-quiz__nav">
            <button type="button" class="volt-quiz__back" data-quiz-back hidden>&larr; {{ 'sections.newsletter_diagnostic.back' | t: default: 'Back' }}</button>
          </div>
        </form>
      </diagnostic-quiz>
    </div>

    {%- comment -%} RIGHT — newsletter capture {%- endcomment -%}
    <div class="volt-diag__right">
      <p class="volt-diag__nllabel">{{ section.settings.newsletter_heading }}</p>
      {%- if section.settings.newsletter_body != blank -%}<p class="volt-diag__nlbody">{{ section.settings.newsletter_body }}</p>{%- endif -%}
      {%- form 'customer', class: 'volt-diag__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="volt-diag__success" role="status">{{ 'sections.newsletter_diagnostic.nl_success' | t: default: 'You are in. Watch your inbox for the first dispatch.' }}</p>
        {%- else -%}
          <label class="visually-hidden" for="VoltDispatch-{{ section.id }}">{{ 'sections.newsletter_diagnostic.nl_placeholder' | t: default: 'Email address' }}</label>
          <div class="volt-diag__field">
            <input id="VoltDispatch-{{ section.id }}" class="volt-diag__input" type="email" name="contact[email]" autocomplete="email" required placeholder="{{ 'sections.newsletter_diagnostic.nl_placeholder' | t: default: 'Email address' }}">
            <button type="submit" class="volt-diag__submit">{{ 'sections.newsletter_diagnostic.nl_submit' | t: default: 'Subscribe' }}</button>
          </div>
          {%- if form.errors -%}<p class="volt-diag__error" role="alert">{{ form.errors | default_errors }}</p>{%- endif -%}
        {%- endif -%}
        <p class="volt-diag__consent">{{ section.settings.consent_text }}</p>
      {%- endform -%}
    </div>

  </div>
</div>

{% stylesheet %}
  .volt-diag { background: var(--color-ink); color: var(--color-bg); }
  .volt-diag__inner { max-width: var(--page-width); margin-inline: auto; padding: calc(clamp(64px, 9vw, 100px) + 20px) 28px; }
  .volt-diag__grid { display: grid; grid-template-columns: 60fr 40fr; gap: clamp(32px, 5vw, 72px); align-items: start; }
  .volt-diag__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-acid); margin: 0; }
  .volt-diag__heading { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(35px, 3.9vw, 60px) * var(--section-heading-scale, 1)); line-height: 1.02; letter-spacing: -.02em; color: var(--color-bg); margin: 16px 0 0; }
  .volt-diag__body { font-size: 15px; line-height: 1.6; color: rgba(240,238,234,.7); margin: 16px 0 0; max-width: 46ch; }

  .volt-quiz { display: block; margin-top: clamp(28px, 4vw, 40px); }
  .volt-quiz__bar { position: relative; height: 2px; background: rgba(240,238,234,.15); overflow: hidden; }
  .volt-quiz__bar-fill { display: block; height: 100%; width: 25%; background: var(--color-acid); transition: width var(--dur-med) var(--ease); }
  .volt-quiz__progress { font-family: var(--font-mono); font-size: 11px; color: rgba(240,238,234,.5); margin: 10px 0 0; }
  .volt-quiz__form { margin-top: 22px; }
  .volt-quiz__step { border: 0; padding: 0; min-inline-size: 0; }
  .volt-quiz__step[hidden] { display: none; }
  .volt-quiz__legend { padding: 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: rgba(240,238,234,.5); margin-bottom: 16px; }
  .volt-quiz__options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .volt-quiz__opt { display: flex; align-items: center; justify-content: space-between; gap: 10px; text-align: left; background: rgba(240,238,234,.05); border: 1px solid rgba(240,238,234,.2); color: var(--color-bg); padding: 16px 18px; font-family: var(--font-body); font-weight: 500; font-size: 14px; cursor: pointer; transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease); }
  .volt-quiz__opt:hover { border-color: var(--color-bg); transition-delay: .03s; }
  .volt-quiz__opt:active { transform: translateY(1px); }
  .volt-quiz__opt[aria-pressed="true"] { border-color: var(--color-acid); background: var(--color-acid); color: var(--color-ink); }
  .volt-quiz__price { font-family: var(--font-mono); font-size: 11px; color: var(--color-acid); white-space: nowrap; }
  .volt-quiz__opt[aria-pressed="true"] .volt-quiz__price { color: var(--color-ink); }
  .volt-quiz__cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 22px; width: 100%; justify-content: center; background: var(--color-acid); color: var(--color-ink); font-family: var(--font-body); font-weight: 500; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; padding: 15px 24px; text-decoration: none; }
  .volt-quiz__nav { margin-top: 16px; min-height: 20px; }
  .volt-quiz__back { background: none; border: 0; color: rgba(240,238,234,.6); font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; }
  .volt-quiz__back:hover { color: var(--color-bg); transition-delay: .03s; }
  .volt-quiz__back[hidden] { display: none; }

  .volt-diag__right { border: 1px solid rgba(240,238,234,.18); background: rgba(240,238,234,.04); padding: clamp(24px, 3vw, 36px); }
  .volt-diag__nllabel { font-family: var(--font-mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-acid); margin: 0; }
  .volt-diag__nlbody { font-size: 14px; line-height: 1.6; color: rgba(240,238,234,.7); margin: 12px 0 0; max-width: 36ch; }
  .volt-diag__form { margin-top: 22px; }
  .volt-diag__field { display: flex; gap: 10px; }
  .volt-diag__input { flex: 1 1 auto; min-width: 0; background: rgba(240,238,234,.06); border: 1px solid rgba(240,238,234,.25); color: var(--color-bg); font-family: var(--font-body); font-size: 15px; padding: 14px 16px; }
  .volt-diag__input::placeholder { color: rgba(240,238,234,.45); }
  .volt-diag__input:focus { outline: none; border-color: var(--color-acid); }
  .volt-diag__submit { flex: 0 0 auto; background: var(--color-acid); color: var(--color-ink); border: 0; font-family: var(--font-body); font-weight: 500; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; padding: 14px 22px; cursor: pointer; }
  .volt-diag__success { font-family: var(--font-mono); font-size: 13px; color: var(--color-acid); }
  .volt-diag__error { font-family: var(--font-mono); font-size: 12px; color: var(--color-danger); margin-top: 10px; }
  .volt-diag__consent { font-family: var(--font-mono); font-size: 10px; letter-spacing: .04em; color: rgba(240,238,234,.4); margin-top: 14px; line-height: 1.6; }

  @media (max-width: 990px) { .volt-diag__grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .volt-quiz__options { grid-template-columns: 1fr; } .volt-diag__field { flex-direction: column; } .volt-diag__submit { width: 100%; } }
{% endstylesheet %}

<script>
  (function () {
    if (customElements.get('diagnostic-quiz')) return;
    class DiagnosticQuiz extends HTMLElement {
      connectedCallback() {
        this.steps = Array.from(this.querySelectorAll('[data-quiz-fieldset]'));
        this.fill = this.querySelector('[data-quiz-fill]');
        this.stepLabel = this.querySelector('[data-quiz-step]');
        this.backBtn = this.querySelector('[data-quiz-back]');
        this.cta = this.querySelector('[data-quiz-cta]');
        this.index = 0; this.total = this.steps.length;
        this.base = this.getAttribute('data-base') || '/products/volt-membership-';
        this.tiers = {
          starter: this.getAttribute('data-tier-starter') || 'starter',
          performance: this.getAttribute('data-tier-performance') || 'performance',
          elite: this.getAttribute('data-tier-elite') || 'elite'
        };
        var stored = null; try { stored = localStorage.getItem('volt-tier'); } catch (e) {}
        if (stored && this.tiers[stored]) this.setTier(stored);
        this.addEventListener('click', this.onClick.bind(this));
        this.show(0);
      }
      onClick(e) {
        var ans = e.target.closest('[data-quiz-answer]');
        if (ans) { this.answer(ans); return; }
        if (e.target.closest('[data-quiz-back]')) this.show(this.index - 1);
      }
      answer(btn) {
        var field = btn.closest('[data-quiz-fieldset]');
        field.querySelectorAll('[data-quiz-answer]').forEach(function (b) { b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'); });
        var tier = btn.getAttribute('data-quiz-tier');
        if (tier) { this.setTier(tier); return; }
        var self = this;
        window.setTimeout(function () { if (self.index < self.total - 1) self.show(self.index + 1); }, 220);
      }
      setTier(tier) {
        if (!this.tiers[tier]) return;
        try { localStorage.setItem('volt-tier', tier); } catch (e) {}
        if (this.cta) this.cta.setAttribute('href', this.base + this.tiers[tier]);
        var last = this.steps[this.total - 1];
        if (last) last.querySelectorAll('[data-quiz-tier]').forEach(function (b) { b.setAttribute('aria-pressed', b.getAttribute('data-quiz-tier') === tier ? 'true' : 'false'); });
      }
      show(i) {
        if (i < 0 || i >= this.total) return;
        this.index = i;
        this.steps.forEach(function (s, n) { var a = n === i; s.hidden = !a; if (a) s.setAttribute('aria-current', 'step'); else s.removeAttribute('aria-current'); });
        if (this.fill) this.fill.style.width = ((i + 1) / this.total * 100) + '%';
        if (this.stepLabel) this.stepLabel.textContent = ('0' + (i + 1)).slice(-2);
        if (this.backBtn) this.backBtn.hidden = i === 0;
        var f = this.steps[i].querySelector('[data-quiz-answer]'); if (f) f.focus();
      }
    }
    customElements.define('diagnostic-quiz', DiagnosticQuiz);
  })();
</script>

{% schema %}
{
  "name": "t:sections.newsletter_diagnostic.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "text", "id": "eyebrow", "label": "t:sections.newsletter_diagnostic.eyebrow", "default": "// Diagnostic Capture" },
    { "type": "text", "id": "heading", "label": "t:sections.newsletter_diagnostic.heading", "default": "What's your training level?" },
    { "type": "textarea", "id": "body", "label": "t:sections.newsletter_diagnostic.body", "default": "Four questions. Sixty seconds. We map your goals, frequency and obstacles to the protocol built to move your numbers." },
    { "type": "header", "content": "t:sections.newsletter_diagnostic.tiers_header" },
    { "type": "text", "id": "tier_starter_handle", "label": "t:sections.newsletter_diagnostic.tier_starter_handle", "info": "t:sections.newsletter_diagnostic.tier_handle_info", "default": "starter" },
    { "type": "text", "id": "tier_performance_handle", "label": "t:sections.newsletter_diagnostic.tier_performance_handle", "default": "performance" },
    { "type": "text", "id": "tier_elite_handle", "label": "t:sections.newsletter_diagnostic.tier_elite_handle", "default": "elite" },
    { "type": "header", "content": "t:sections.newsletter_diagnostic.newsletter_header" },
    { "type": "text", "id": "newsletter_heading", "label": "t:sections.newsletter_diagnostic.newsletter_heading", "default": "Or join the dispatch" },
    { "type": "textarea", "id": "newsletter_body", "label": "t:sections.newsletter_diagnostic.newsletter_body", "default": "Weekly performance science, member protocols and early access to drops. No filler." },
    { "type": "text", "id": "consent_text", "label": "t:sections.newsletter_diagnostic.consent_text", "default": "By subscribing you agree to receive marketing emails. Unsubscribe anytime." },
    { "type": "header", "content": "t:sections.animation.header" },
    { "type": "checkbox", "id": "enable_animations", "label": "t:sections.animation.enable", "default": true },
    { "type": "select", "id": "heading_animation", "label": "t:sections.animation.heading", "default": "split-words", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "split-chars", "label": "t:sections.animation.opt_split_chars" },
      { "value": "split-words", "label": "t:sections.animation.opt_split_words" },
      { "value": "split-lines", "label": "t:sections.animation.opt_split_lines" },
      { "value": "fade-up", "label": "t:sections.animation.opt_fade_up" },
      { "value": "clip-bottom", "label": "t:sections.animation.opt_clip_bottom" },
      { "value": "clip-left", "label": "t:sections.animation.opt_clip_left" }
    ] },
    { "type": "range", "id": "section_delay", "label": "t:sections.animation.delay", "min": 0, "max": 800, "step": 50, "unit": "ms", "default": 0 }
  ],
  "presets": [
    { "name": "t:sections.newsletter_diagnostic.name" }
  ]
}
{% endschema %}
