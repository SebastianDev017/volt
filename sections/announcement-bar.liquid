{%- liquid
  assign bg = section.settings.bg_color | default: '#D4FF00'
  assign tc = section.settings.text_color | default: '#0D0C0B'
-%}
<style>
  #shopify-section-{{ section.id }} .volt-announce { --abg: {{ bg }}; --atext: {{ tc }}; }
</style>
<volt-announce class="volt-announce">
  <div class="volt-announce__inner">
    {%- if section.settings.message != blank -%}<span class="volt-announce__msg">{{ section.settings.message }}</span>{%- endif -%}
    {%- if section.settings.show_countdown and section.settings.countdown_end_date != blank -%}
      <countdown-timer class="volt-announce__cd" data-end="{{ section.settings.countdown_end_date }}"><span data-cd-display>--:--:--</span></countdown-timer>
    {%- endif -%}
    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <a class="volt-announce__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
    {%- endif -%}
  </div>
  <button class="volt-announce__x" data-announce-dismiss aria-label="{{ 'sections.announcement_bar.dismiss' | t: default: 'Dismiss' }}">&#10005;</button>
</volt-announce>

{% stylesheet %}
  .volt-announce { display: block; position: relative; background: var(--abg); color: var(--atext); }
  .volt-announce[hidden] { display: none; }
  .volt-announce__inner { min-height: 38px; display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; padding: 6px 44px; font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; }
  .volt-announce__cd [data-cd-display] { background: var(--color-ink); color: var(--color-acid); padding: 3px 8px; }
  .volt-announce__cta { color: inherit; text-decoration: underline; text-underline-offset: 3px; }
  .volt-announce__x { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); background: none; border: 0; color: inherit; font-size: 14px; line-height: 1; padding: 4px; cursor: pointer; opacity: .65; }
  .volt-announce__x:hover { opacity: 1; }
{% endstylesheet %}

<script>
  if (!customElements.get('volt-announce')) {
    customElements.define('volt-announce', class extends HTMLElement {
      connectedCallback() {
        try { if (localStorage.getItem('volt-announce-dismissed') === '1') this.hidden = true; } catch (e) {}
        var b = this.querySelector('[data-announce-dismiss]');
        if (b) b.addEventListener('click', () => { this.hidden = true; try { localStorage.setItem('volt-announce-dismissed', '1'); } catch (e) {} });
      }
    });
  }
</script>

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "settings": [
    { "type": "text", "id": "message", "label": "t:sections.announcement_bar.message", "default": "Founding member rate — ends in" },
    { "type": "header", "content": "t:sections.announcement_bar.countdown_header" },
    { "type": "checkbox", "id": "show_countdown", "label": "t:sections.announcement_bar.show_countdown", "default": true },
    { "type": "text", "id": "countdown_end_date", "label": "t:sections.announcement_bar.countdown_end_date", "info": "t:sections.announcement_bar.countdown_end_date_info", "default": "2026-12-31T23:59:59" },
    { "type": "text", "id": "cta_text", "label": "t:sections.announcement_bar.cta_text" },
    { "type": "url", "id": "cta_url", "label": "t:sections.announcement_bar.cta_url" },
    { "type": "header", "content": "t:sections.announcement_bar.appearance_header" },
    { "type": "color", "id": "bg_color", "label": "t:sections.announcement_bar.bg_color", "default": "#D4FF00" },
    { "type": "color", "id": "text_color", "label": "t:sections.announcement_bar.text_color", "default": "#0D0C0B" }
  ],
  "presets": [
    { "name": "t:sections.announcement_bar.name" }
  ]
}
{% endschema %}
