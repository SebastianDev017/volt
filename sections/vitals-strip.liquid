{% render 'section-style', section: section %}
<section class="volt-vitals" data-animate aria-label="{{ 'sections.vitals_strip.aria' | t: default: 'Member stats' }}">
  <div class="volt-vitals__wrap">
    <div class="volt-vitals__track">
      {%- for n in (1..2) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'institutional' -%}
            <span class="volt-vitals__item volt-vitals__item--inst" {{ block.shopify_attributes }}>{{ block.settings.text }}</span><span class="volt-vitals__sep" aria-hidden="true">/</span>
          {%- else -%}
            <span class="volt-vitals__item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span><span class="volt-vitals__sep" aria-hidden="true">/</span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-vitals { background: var(--color-ink); }
  .volt-vitals__wrap { overflow: hidden; white-space: nowrap; }
  .volt-vitals__track { display: inline-flex; align-items: center; padding: 15px 0; animation: volt-marquee 30s linear infinite; }
  .volt-vitals:hover .volt-vitals__track { animation-play-state: paused; }
  .volt-vitals__item, .volt-vitals__sep { font-family: var(--font-mono); font-size: 13px; letter-spacing: .1em; color: var(--color-acid); padding-right: 32px; white-space: nowrap; }
  .volt-vitals__sep { opacity: .4; }
  /* Institutional credibility slot (Momentous/Oura) — inverted chip so certification/athlete stats read differently from member stats */
  .volt-vitals__item--inst { background: var(--color-acid); color: var(--color-ink); padding: 3px 10px; margin-right: 32px; padding-right: 10px; }
  @media (prefers-reduced-motion: reduce) { .volt-vitals__track { animation: none; white-space: normal; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.vitals_strip.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.vitals_strip.blocks.stat.name",
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.vitals_strip.blocks.stat.text", "default": "2,400 MEMBERS" }
      ]
    },
    {
      "type": "institutional",
      "name": "t:sections.vitals_strip.blocks.institutional.name",
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.vitals_strip.blocks.institutional.text", "info": "t:sections.vitals_strip.blocks.institutional.text_info", "default": "NSF CERTIFIED FACILITY" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.vitals_strip.name",
      "blocks": [
        { "type": "stat", "settings": { "text": "2,400 MEMBERS" } },
        { "type": "stat", "settings": { "text": "847 CLASSES/MONTH" } },
        { "type": "institutional", "settings": { "text": "NSF CERTIFIED FACILITY" } },
        { "type": "stat", "settings": { "text": "94% RETENTION" } },
        { "type": "stat", "settings": { "text": "AVG FIRST PR: WEEK 6" } },
        { "type": "institutional", "settings": { "text": "TRUSTED BY 40+ PRO ATHLETES" } },
        { "type": "stat", "settings": { "text": "+3.2T STRAIN AVG" } }
      ]
    }
  ]
}
{% endschema %}
