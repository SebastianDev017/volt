{%- liquid
  assign menu = linklists[settings.menu]
  if customer
    assign account_href = routes.account_url
  else
    assign account_href = routes.account_login_url
  endif
  assign logo_alt = shop.name | escape
-%}
<site-header class="volt-header" data-sticky="{{ section.settings.enable_sticky }}" data-transparent="{% if settings.transparent_hero %}true{% else %}false{% endif %}" data-nav-upper="{% if settings.nav_uppercase != false %}true{% else %}false{% endif %}" data-progress="{% if settings.header_scroll_indicator %}true{% else %}false{% endif %}">
  <div class="volt-header__bar">
    <a href="{{ routes.root_url }}" class="volt-header__logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 240 | image_tag: loading: 'eager', widths: '120, 240', class: 'volt-header__logoimg', alt: logo_alt }}
      {%- else -%}{{ settings.logo_text | default: shop.name }}{%- endif -%}
    </a>

    <nav class="volt-header__nav" aria-label="{{ 'sections.header_main.primary_nav' | t: default: 'Primary' }}">
      {%- for link in menu.links -%}
        {%- if link.links.size > 0 and settings.mega_menu_enable -%}
          <div class="volt-nav__item">
            <a href="{{ link.url }}" class="volt-nav__link" aria-haspopup="true">{{ link.title }}</a>
            <div class="volt-mega">
              <div class="volt-mega__inner">
                <div class="volt-mega__cols">
                  {%- for child in link.links limit: 4 -%}
                    <div class="volt-mega__col">
                      <a href="{{ child.url }}" class="volt-mega__heading">{{ child.title }}</a>
                      {%- if child.links.size > 0 -%}
                        <ul class="volt-mega__list">
                          {%- for gc in child.links -%}<li><a href="{{ gc.url }}">{{ gc.title }}</a></li>{%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
                <a href="/pages/membership" class="volt-mega__promo">
                  <span class="volt-mega__promoeyebrow">{{ 'sections.header_main.promo_eyebrow' | t: default: 'Members only' }}</span>
                  <span class="volt-mega__promotitle">{{ 'sections.header_main.promo_title' | t: default: 'Train with data, not guesswork.' }}</span>
                  <span class="volt-mega__promocta">{{ 'sections.header_main.promo_cta' | t: default: 'Start your protocol' }} &rarr;</span>
                </a>
              </div>
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="volt-nav__link">{{ link.title }}</a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="volt-header__actions">
      <a href="{{ routes.search_url }}" class="volt-header__icon" aria-label="{{ 'sections.header_main.search' | t: default: 'Search' }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <a href="{{ account_href }}" class="volt-header__account" aria-label="{{ 'sections.header_main.account' | t: default: 'Account' }}">
        {%- if customer -%}<span class="volt-header__initial">{{ customer.first_name | slice: 0 | upcase | default: 'A' }}</span>
        {%- else -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg>{%- endif -%}
      </a>
      <a href="{{ routes.cart_url }}" class="volt-header__icon volt-header__cart" aria-label="{{ 'sections.header_main.cart' | t: default: 'Cart' }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 7h12l-1.2 12.2a2 2 0 0 1-2 1.8H9.2a2 2 0 0 1-2-1.8Z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg>
        <span class="volt-header__count" data-cart-count>{{ cart.item_count }}</span>
      </a>
      {%- if settings.header_cta_label != blank -%}
        <a href="{{ settings.header_cta_url | default: routes.root_url }}" class="volt-header__cta" data-magnetic data-magnetic-strength="0.25">{{ settings.header_cta_label }}</a>
      {%- endif -%}
      <button type="button" class="volt-header__burger" data-drawer-open aria-label="{{ 'sections.header_main.open_menu' | t: default: 'Open menu' }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  {%- if settings.header_scroll_indicator -%}<span class="volt-header__progress" data-header-progress aria-hidden="true"></span>{%- endif -%}

  <div class="volt-drawer" data-drawer hidden>
    <div class="volt-drawer__head">
      <span class="volt-header__logo">{{ settings.logo_text | default: shop.name }}</span>
      <button type="button" class="volt-header__icon" data-drawer-close aria-label="{{ 'sections.header_main.close_menu' | t: default: 'Close menu' }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>
    <nav class="volt-drawer__nav" aria-label="{{ 'sections.header_main.primary_nav' | t: default: 'Primary' }}">
      {%- for link in menu.links -%}
        <a href="{{ link.url }}" class="volt-drawer__link">{{ link.title }}</a>
        {%- if link.links.size > 0 -%}
          {%- for child in link.links -%}<a href="{{ child.url }}" class="volt-drawer__sub">{{ child.title }}</a>{%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </nav>
  </div>
</site-header>

{% stylesheet %}
  .volt-header { display: block; z-index: var(--z-header); transition: background .35s var(--ease), border-color .35s var(--ease), box-shadow .35s var(--ease), top .35s var(--ease); }
  /* Template-driven base state (CSS only). Non-homepage: solid sticky, always visible. */
  body:not(.template-index) .volt-header[data-sticky="true"] { position: sticky; top: 0; background: var(--color-bg); border-bottom: 1px solid var(--color-border); }
  /* Homepage: transparent header fixed over the hero (top:auto keeps it below the announcement bar); solid + blur once scrolled past 80px. */
  body.template-index .volt-header[data-sticky="true"] { position: fixed; left: 0; right: 0; background: transparent; border-bottom: 1px solid transparent; }
  body.template-index .volt-header[data-sticky="true"].is-stuck { top: 0; background: var(--color-bg); -webkit-backdrop-filter: blur(24px) saturate(160%); backdrop-filter: blur(24px) saturate(160%); border-bottom-color: var(--color-border); box-shadow: 0 2px 40px rgba(13,12,11,.06); }
  /* Transparent-over-hero (homepage, pre-scroll): light nav/logo/icons for contrast on the dark image side; a subtle top gradient keeps them legible on the light side too. Reverts to ink once .is-stuck (solid) kicks in. */
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-nav__link,
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-header__logo,
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-header__icon,
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-header__account,
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-header__count,
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck) .volt-header__burger { color: #FFFFFF; }
  body.template-index .volt-header[data-sticky="true"]:not(.is-stuck)::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,12,11,.18) 0%, transparent 100%); z-index: -1; pointer-events: none; }
  /* Merchant opt-out: non-sticky static header. */
  .volt-header[data-sticky="false"] { position: static; background: var(--color-bg); border-bottom: 1px solid var(--color-border); }
  .volt-header[data-nav-upper="false"] .volt-nav__link { text-transform: none; }
  .volt-header__cta { display: inline-flex; align-items: center; font-family: var(--font-body); font-weight: 500; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; background: var(--color-acid); color: var(--on-acid); padding: 9px 16px; text-decoration: none; transition: filter .2s var(--ease); }
  .volt-header__cta:hover { filter: brightness(1.05); }
  .volt-header__progress { position: absolute; left: 0; bottom: 0; height: 2px; width: 0; background: var(--color-acid); transition: width .1s linear; }
  @media (max-width: 600px) { .volt-header__cta { display: none; } }
  .volt-header__bar { max-width: var(--page-width); margin-inline: auto; height: calc(var(--header-height) - 4px); padding: 0 28px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .volt-header__logo { font-family: var(--font-display); font-weight: 800; font-size: 20px; letter-spacing: -.02em; color: var(--color-ink); text-decoration: none; flex-shrink: 0; }
  .volt-header__logoimg { height: 26px; width: auto; }

  .volt-header__nav { display: flex; align-items: center; gap: 34px; }
  .volt-nav__item { position: static; }
  /* Nav links: scramble-text hover (JS, FIX 11) replaces the old underline. Colour fades via this transition; JS toggles inline acid on hover and clears it on leave. */
  .volt-nav__link { font-family: var(--font-body); font-size: 10.5px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; padding: 4px 0; position: relative; transition: color var(--dur-med) var(--ease); }
  .volt-nav__link:hover { color: var(--color-acid-accessible); }

  .volt-mega { position: absolute; left: 0; right: 0; top: 100%; background: var(--color-bg); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); opacity: 0; visibility: hidden; transform: translateY(-8px); transition: opacity var(--dur-med) var(--ease), transform var(--dur-med) var(--ease), visibility var(--dur-med); z-index: 5; }
  .volt-nav__item:hover .volt-mega, .volt-nav__item:focus-within .volt-mega { opacity: 1; visibility: visible; transform: none; }
  .volt-mega__inner { max-width: var(--page-width); margin-inline: auto; padding: 40px 28px; display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1.2fr; gap: 32px; }
  .volt-mega__cols { grid-column: 1 / 5; display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .volt-mega__heading { font-family: var(--font-display); font-weight: 700; font-size: 12px; color: var(--color-ink); text-decoration: none; display: block; margin-bottom: 14px; }
  .volt-mega__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
  .volt-mega__list a { font-size: 10.5px; color: var(--color-mid); text-decoration: none; }
  .volt-mega__list a:hover { color: var(--color-ink); }
  .volt-mega__promo { display: flex; flex-direction: column; gap: 8px; background: var(--color-ink); color: var(--color-bg); padding: 24px; text-decoration: none; }
  .volt-mega__promoeyebrow { font-family: var(--font-mono); font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: var(--color-acid); }
  .volt-mega__promotitle { font-family: var(--font-display); font-weight: 700; font-size: 20px; line-height: 1.1; }
  .volt-mega__promocta { font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; text-transform: uppercase; color: var(--color-acid); margin-top: auto; }

  .volt-header__actions { display: flex; align-items: center; gap: 18px; flex-shrink: 0; }
  .volt-header__icon { display: flex; align-items: center; color: var(--color-ink); background: none; border: 0; cursor: pointer; padding: 4px; text-decoration: none; position: relative; }
  .volt-header__account { display: flex; align-items: center; gap: 7px; color: var(--color-ink); text-decoration: none; padding: 4px; }
  .volt-header__initial { display: grid; place-items: center; width: 26px; height: 26px; border-radius: 50%; background: var(--color-ink); color: var(--color-bg); font-family: var(--font-mono); font-size: 11px; }
  .volt-header__tier { font-family: var(--font-mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; background: var(--color-ink); color: var(--color-acid); padding: 3px 6px; }
  .volt-header__cart { gap: 6px; }
  .volt-header__count { font-family: var(--font-mono); font-size: 11px; }
  .volt-header__burger { display: none; }

  .volt-drawer { position: fixed; inset: 0 0 0 auto; width: min(360px, 86vw); background: var(--color-bg); border-left: 1px solid var(--color-border); z-index: var(--z-drawer); padding: 20px 24px; overflow-y: auto; transform: translateX(100%); transition: transform var(--dur-med) var(--ease); }
  .volt-drawer[hidden] { display: block; }
  .volt-header.drawer-open .volt-drawer { transform: none; }
  .volt-header.drawer-open::before { content: ""; position: fixed; inset: 0; background: rgba(13,12,11,.5); z-index: calc(var(--z-drawer) - 1); }
  .volt-drawer__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .volt-drawer__nav { display: flex; flex-direction: column; }
  .volt-drawer__link { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: var(--color-ink); text-decoration: none; padding: 12px 0; border-bottom: 1px solid var(--color-border); }
  .volt-drawer__sub { font-size: 11px; color: var(--color-mid); text-decoration: none; padding: 7px 0 7px 14px; }

  @media (max-width: 900px) {
    .volt-header__nav { display: none; }
    .volt-header__burger { display: flex; align-items: center; color: var(--color-ink); background: none; border: 0; cursor: pointer; padding: 4px; }
    .volt-mega { display: none; }
  }
  @media (min-width: 901px) { .volt-drawer { display: none; } }
{% endstylesheet %}

<script>
  if (!customElements.get('site-header')) {
    customElements.define('site-header', class extends HTMLElement {
      connectedCallback() {
        this.open = this.querySelector('[data-drawer-open]');
        this.close = this.querySelector('[data-drawer-close]');
        if (this.open) this.open.addEventListener('click', () => this.classList.add('drawer-open'));
        if (this.close) this.close.addEventListener('click', () => this.classList.remove('drawer-open'));
        this.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.classList.remove('drawer-open'); });
        this.addEventListener('click', (e) => { if (e.target === this) this.classList.remove('drawer-open'); });
        var progress = this.querySelector('[data-header-progress]');
        if (this.getAttribute('data-sticky') !== 'false' || progress) {
          var onScroll = () => {
            this.classList.toggle('is-stuck', window.scrollY > 80);
            if (progress) {
              var h = document.documentElement.scrollHeight - window.innerHeight;
              progress.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + '%';
            }
          };
          onScroll(); window.addEventListener('scroll', onScroll, { passive: true });
        }
      }
    });
  }
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    { "type": "paragraph", "content": "t:sections.header_main.global_note" },
    { "type": "image_picker", "id": "logo", "label": "t:sections.header_main.logo" },
    { "type": "checkbox", "id": "enable_sticky", "label": "t:sections.header_main.enable_sticky", "default": true }
  ]
}
{% endschema %}
