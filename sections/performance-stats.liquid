{% render 'section-style', section: section %}
<section class="volt-stats" data-animate>
  <div class="volt-stats__inner">
    <div class="volt-stats__grid" {% render 'anim-attrs', value: section.settings.cards_animation, enabled: section.settings.enable_animations %}>
      {%- for block in section.blocks -%}
        {%- liquid
          assign raw = block.settings.value | strip
          assign numeric = raw | remove: ','
          assign parts = numeric | split: '.'
          assign decimals = 0
          if parts.size > 1
            assign decimals = parts[1] | size
          endif
        -%}
        <div class="volt-stats__cell" data-stagger-item {{ block.shopify_attributes }}>
          <div class="volt-stats__num">
            {%- if section.settings.enable_animations != false -%}
              <span class="volt-stats__count" data-counter="{{ numeric }}"{% if raw contains ',' %} data-counter-sep="true"{% endif %}{% if decimals > 0 %} data-counter-decimals="{{ decimals }}"{% endif %}>{{ block.settings.value }}</span>
            {%- else -%}
              <span class="volt-stats__count">{{ block.settings.value }}</span>
            {%- endif -%}
            {%- if block.settings.suffix != blank -%}<span class="volt-stats__suffix">{{ block.settings.suffix }}</span>{%- endif -%}
          </div>
          <div class="volt-stats__bar"></div>
          <div class="volt-stats__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-stats__inner { max-width: var(--page-width); margin-inline: auto; padding: 104px 28px; }
  .volt-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .volt-stats__cell { background: var(--color-bg); padding: 40px 28px; }
  .volt-stats__num { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(46px, 5vw, 69px) * var(--section-heading-scale, 1)); line-height: 1; letter-spacing: -.02em; }
  .volt-stats__count { color: var(--color-ink); }
  .volt-stats__suffix { color: var(--color-acid-accessible); }
  .volt-stats__bar { width: 34px; height: 4px; background: var(--color-acid); margin: 16px 0 12px; }
  .volt-stats__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  @media (max-width: 860px) { .volt-stats__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .volt-stats__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.performance_stats.name",
  "tag": "section",
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.performance_stats.blocks.stat.name",
      "settings": [
        { "type": "text", "id": "value", "label": "t:sections.performance_stats.blocks.stat.value", "default": "2,400" },
        { "type": "text", "id": "suffix", "label": "t:sections.performance_stats.blocks.stat.suffix", "default": "+" },
        { "type": "text", "id": "label", "label": "t:sections.performance_stats.blocks.stat.label", "default": "Active members" }
      ]
    }
  ],
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "header", "content": "t:sections.animation.header" },
    { "type": "checkbox", "id": "enable_animations", "label": "t:sections.animation.enable", "default": true },
    { "type": "select", "id": "cards_animation", "label": "t:sections.animation.cards", "default": "stagger-up", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "stagger-up", "label": "t:sections.animation.opt_stagger_up" },
      { "value": "stagger-fade", "label": "t:sections.animation.opt_stagger_fade" },
      { "value": "stagger-scale", "label": "t:sections.animation.opt_stagger_scale" },
      { "value": "stagger-rotate", "label": "t:sections.animation.opt_stagger_rotate" }
    ] }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.performance_stats.name",
      "blocks": [
        { "type": "stat", "settings": { "value": "2,400", "suffix": "+", "label": "Active members" } },
        { "type": "stat", "settings": { "value": "94", "suffix": "%", "label": "Retention rate" } },
        { "type": "stat", "settings": { "value": "847", "suffix": "", "label": "Classes / month" } },
        { "type": "stat", "settings": { "value": "6.2", "suffix": "T", "label": "Avg strain goal" } }
      ]
    }
  ]
}
{% endschema %}
