<section class="volt-stats" data-animate>
  <div class="volt-stats__inner">
    <div class="volt-stats__grid">
      {%- for block in section.blocks -%}
        <div class="volt-stats__cell" {{ block.shopify_attributes }}>
          <div class="volt-stats__num">{{ block.settings.value }}{%- if block.settings.suffix != blank -%}<span>{{ block.settings.suffix }}</span>{%- endif -%}</div>
          <div class="volt-stats__bar"></div>
          <div class="volt-stats__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-stats__inner { max-width: var(--page-width); margin-inline: auto; padding: 84px 28px; }
  .volt-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .volt-stats__cell { background: var(--color-bg); padding: 40px 28px; }
  .volt-stats__num { font-family: var(--font-display); font-weight: 800; font-size: clamp(40px, 4.4vw, 60px); line-height: 1; letter-spacing: -.02em; }
  .volt-stats__num span { color: var(--color-acid); }
  .volt-stats__bar { width: 34px; height: 4px; background: var(--color-acid); margin: 16px 0 12px; }
  .volt-stats__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  @media (max-width: 860px) { .volt-stats__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .volt-stats__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.performance_stats.name",
  "tag": "section",
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.performance_stats.blocks.stat.name",
      "settings": [
        { "type": "text", "id": "value", "label": "t:sections.performance_stats.blocks.stat.value", "default": "2,400" },
        { "type": "text", "id": "suffix", "label": "t:sections.performance_stats.blocks.stat.suffix", "default": "+" },
        { "type": "text", "id": "label", "label": "t:sections.performance_stats.blocks.stat.label", "default": "Active members" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.performance_stats.name",
      "blocks": [
        { "type": "stat", "settings": { "value": "2,400", "suffix": "+", "label": "Active members" } },
        { "type": "stat", "settings": { "value": "94", "suffix": "%", "label": "Retention rate" } },
        { "type": "stat", "settings": { "value": "847", "suffix": "", "label": "Classes / month" } },
        { "type": "stat", "settings": { "value": "6.2", "suffix": "T", "label": "Avg strain goal" } }
      ]
    }
  ]
}
{% endschema %}
