{%- liquid
  assign has_quote = false
  if section.settings.show_quote and section.settings.quote != blank
    assign has_quote = true
  endif
-%}
<div class="volt-stats section" data-animate>
  <div class="section-inner volt-stats__inner{% if has_quote %} volt-stats__inner--split{% endif %}">
    <div class="volt-stats__col">
      {%- if section.settings.heading != blank -%}
        <p class="eyebrow volt-stats__eyebrow" data-animate>{{ section.settings.heading }}</p>
      {%- endif -%}
      <div class="volt-stats__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="volt-stats__stat" data-animate data-animate-delay="{{ forloop.index0 | times: 100 | at_most: 300 }}" {{ block.shopify_attributes }}>
              <p class="h0 volt-stats__value">{{ block.settings.value }}</p>
              <p class="label muted volt-stats__label">{{ block.settings.label }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if has_quote -%}
      <figure class="volt-stats__quote" data-animate data-animate-delay="200">
        <blockquote class="volt-stats__quote-text">{{ section.settings.quote }}</blockquote>
        {%- if section.settings.quote_author != blank -%}
          <figcaption class="label muted volt-stats__quote-author">{{ section.settings.quote_author }}</figcaption>
        {%- endif -%}
      </figure>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .volt-stats { background: var(--color-surface); }
  .volt-stats__inner--split {
    display: grid;
    grid-template-columns: 60% 40%;
    gap: clamp(40px, 6vw, 88px);
    align-items: center;
  }
  .volt-stats__eyebrow { margin-bottom: clamp(28px, 4vw, 48px); }
  .volt-stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .volt-stats__stat {
    background: var(--color-surface);
    padding: clamp(28px, 4vw, 48px);
  }
  .volt-stats__value {
    color: var(--color-acid);
    line-height: 0.92;
    margin-bottom: 14px;
  }
  .volt-stats__label { letter-spacing: 0.16em; }
  .volt-stats__quote {
    border-left: 2px solid var(--color-acid);
    padding-left: clamp(24px, 3vw, 40px);
  }
  .volt-stats__quote-text {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: calc(clamp(22px, 2.4vw, 32px) * var(--heading-scale));
    line-height: 1.18;
    letter-spacing: -0.01em;
  }
  .volt-stats__quote-author { margin-top: 22px; }
  @media (max-width: 900px) {
    .volt-stats__inner--split { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .volt-stats__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.performance_stats.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.performance_stats.heading",
      "info": "t:sections.performance_stats.heading_info",
      "default": "The numbers"
    },
    {
      "type": "header",
      "content": "t:sections.performance_stats.quote_header"
    },
    {
      "type": "checkbox",
      "id": "show_quote",
      "label": "t:sections.performance_stats.show_quote",
      "default": true
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:sections.performance_stats.quote",
      "default": "I stopped guessing. The data told me exactly where to push and when to recover."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "t:sections.performance_stats.quote_author",
      "default": "Member since 2021 — Strength Protocol"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.performance_stats.blocks.stat.name",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "t:sections.performance_stats.blocks.stat.value",
          "default": "2,400+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.performance_stats.blocks.stat.label",
          "default": "Active members"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.performance_stats.name",
      "blocks": [
        { "type": "stat", "settings": { "value": "2,400+", "label": "Active members" } },
        { "type": "stat", "settings": { "value": "94%", "label": "Retention rate" } },
        { "type": "stat", "settings": { "value": "847", "label": "Classes per month" } },
        { "type": "stat", "settings": { "value": "6.2T", "label": "Avg strain goal" } }
      ]
    }
  ]
}
{% endschema %}
