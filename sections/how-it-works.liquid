{% render 'section-style', section: section %}
{%- liquid
  assign last = section.blocks.size | minus: 1
-%}
<section class="volt-rp" data-animate>
  <div class="volt-rp__inner">
    <div class="volt-rp__head">
      {%- if section.settings.eyebrow != blank -%}<div class="volt-rp__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="volt-rp__title" {% render 'anim-attrs', value: section.settings.heading_animation, enabled: section.settings.enable_animations, delay_ms: section.settings.section_delay %}>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="volt-rp__row" {% render 'anim-attrs', value: section.settings.cards_animation, enabled: section.settings.enable_animations %}>
      {%- for block in section.blocks -%}
        <div class="volt-rp__col" data-stagger-item {{ block.shopify_attributes }}>
          <div class="volt-rp__colhead">
            <span class="volt-rp__icon">
              {%- case block.settings.icon -%}
                {%- when 'dumbbell' -%}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M4 9v6M20 9v6M7 7v10M17 7v10M7 12h10"/></svg>
                {%- when 'moon' -%}<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
                {%- when 'leaf' -%}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20c8 0 16-4 16-16-8 0-16 4-16 16zM4 20c2-6 6-9 11-11"/></svg>
                {%- else -%}<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg>
              {%- endcase -%}
            </span>
            <h3 class="volt-rp__colname">{{ block.settings.title }}</h3>
          </div>
          <div class="volt-rp__items">
            {%- assign ap = block.settings.a_product -%}
            {%- assign aname = ap.title | default: block.settings.a_name -%}
            {%- if aname != blank -%}
              <div class="volt-rp__item">
                <div><div class="volt-rp__iname">{{ aname }}</div>{%- if block.settings.a_specs != blank -%}<div class="volt-rp__ispecs">{{ block.settings.a_specs }}</div>{%- endif -%}</div>
                {%- if ap != blank and ap.available -%}
                  {%- form 'product', ap, class: 'volt-rp__form' -%}<input type="hidden" name="id" value="{{ ap.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="volt-rp__add">+ Add</button>{%- endform -%}
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- assign bp = block.settings.b_product -%}
            {%- assign bname = bp.title | default: block.settings.b_name -%}
            {%- if bname != blank -%}
              <div class="volt-rp__item">
                <div><div class="volt-rp__iname">{{ bname }}</div>{%- if block.settings.b_specs != blank -%}<div class="volt-rp__ispecs">{{ block.settings.b_specs }}</div>{%- endif -%}</div>
                {%- if bp != blank and bp.available -%}
                  {%- form 'product', bp, class: 'volt-rp__form' -%}<input type="hidden" name="id" value="{{ bp.selected_or_first_available_variant.id }}"><button type="submit" name="add" class="volt-rp__add">+ Add</button>{%- endform -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
        {%- unless forloop.index0 == last -%}<div class="volt-rp__arrow" aria-hidden="true">&rarr;</div>{%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-rp__inner { max-width: var(--page-width); margin-inline: auto; padding: 104px 28px; }
  .volt-rp__head { margin-bottom: 44px; }
  .volt-rp__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); }
  .volt-rp__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(35px, 3.45vw, 53px) * var(--section-heading-scale, 1)); line-height: 1.02; letter-spacing: -.01em; margin: 14px 0 0; }
  .volt-rp__row { display: flex; align-items: stretch; flex-wrap: wrap; }
  .volt-rp__col { flex: 1; min-width: 230px; border: 1px solid var(--color-border); padding: 30px 26px; display: flex; flex-direction: column; }
  .volt-rp__colhead { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .volt-rp__icon { color: var(--color-acid); display: flex; }
  .volt-rp__colname { font-family: var(--font-display); font-weight: 700; font-size: 19px; margin: 0; }
  .volt-rp__items { display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .volt-rp__item { border: 1px solid var(--color-border); padding: 14px 15px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .volt-rp__iname { font-family: var(--font-display); font-weight: 700; font-size: 14px; }
  .volt-rp__ispecs { font-family: var(--font-mono); font-size: 10px; color: var(--color-mid); margin-top: 3px; }
  .volt-rp__form { flex-shrink: 0; margin: 0; }
  .volt-rp__add { font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; background: var(--color-acid); border: none; color: var(--color-ink); padding: 9px 11px; cursor: pointer; }
  .volt-rp__add:hover { background: var(--color-ink); color: var(--color-bg); transition-delay: .03s; }
  .volt-rp__arrow { display: flex; align-items: center; justify-content: center; padding: 0 8px; color: var(--color-acid); font-size: 22px; font-family: var(--font-mono); }
  @media (max-width: 860px) { .volt-rp__row { flex-direction: column; } .volt-rp__arrow { transform: rotate(90deg); padding: 8px 0; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.how_it_works.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "text", "id": "eyebrow", "label": "t:sections.how_it_works.eyebrow", "default": "// Build Your Stack" },
    { "type": "text", "id": "heading", "label": "t:sections.how_it_works.heading", "default": "The recovery protocol." },
    { "type": "header", "content": "t:sections.animation.header" },
    { "type": "checkbox", "id": "enable_animations", "label": "t:sections.animation.enable", "default": true },
    { "type": "select", "id": "heading_animation", "label": "t:sections.animation.heading", "default": "split-words", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "split-chars", "label": "t:sections.animation.opt_split_chars" },
      { "value": "split-words", "label": "t:sections.animation.opt_split_words" },
      { "value": "split-lines", "label": "t:sections.animation.opt_split_lines" },
      { "value": "fade-up", "label": "t:sections.animation.opt_fade_up" },
      { "value": "clip-bottom", "label": "t:sections.animation.opt_clip_bottom" },
      { "value": "clip-left", "label": "t:sections.animation.opt_clip_left" }
    ] },
    { "type": "select", "id": "cards_animation", "label": "t:sections.animation.cards", "default": "stagger-up", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "stagger-up", "label": "t:sections.animation.opt_stagger_up" },
      { "value": "stagger-fade", "label": "t:sections.animation.opt_stagger_fade" },
      { "value": "stagger-scale", "label": "t:sections.animation.opt_stagger_scale" },
      { "value": "stagger-rotate", "label": "t:sections.animation.opt_stagger_rotate" }
    ] },
    { "type": "range", "id": "section_delay", "label": "t:sections.animation.delay", "min": 0, "max": 800, "step": 50, "unit": "ms", "default": 0 }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "t:sections.how_it_works.blocks.phase.name",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "t:sections.how_it_works.blocks.phase.icon",
          "options": [
            { "value": "bolt", "label": "t:sections.how_it_works.blocks.phase.icon_bolt" },
            { "value": "dumbbell", "label": "t:sections.how_it_works.blocks.phase.icon_dumbbell" },
            { "value": "moon", "label": "t:sections.how_it_works.blocks.phase.icon_moon" },
            { "value": "leaf", "label": "t:sections.how_it_works.blocks.phase.icon_leaf" }
          ],
          "default": "bolt"
        },
        { "type": "text", "id": "title", "label": "t:sections.how_it_works.blocks.phase.title", "default": "Pre-Workout" },
        { "type": "product", "id": "a_product", "label": "t:sections.how_it_works.blocks.phase.a_product" },
        { "type": "text", "id": "a_name", "label": "t:sections.how_it_works.blocks.phase.a_name", "default": "Pre-Workout V2" },
        { "type": "text", "id": "a_specs", "label": "t:sections.how_it_works.blocks.phase.a_specs", "default": "CAF 200mg · BETA-AL" },
        { "type": "product", "id": "b_product", "label": "t:sections.how_it_works.blocks.phase.b_product" },
        { "type": "text", "id": "b_name", "label": "t:sections.how_it_works.blocks.phase.b_name", "default": "Creatine Mono" },
        { "type": "text", "id": "b_specs", "label": "t:sections.how_it_works.blocks.phase.b_specs", "default": "5g · CREAPURE®" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.how_it_works.name",
      "blocks": [
        { "type": "phase", "settings": { "icon": "bolt", "title": "Pre-Workout", "a_name": "Pre-Workout V2", "a_specs": "CAF 200mg · BETA-AL", "b_name": "Creatine Mono", "b_specs": "5g · CREAPURE®" } },
        { "type": "phase", "settings": { "icon": "dumbbell", "title": "Training", "a_name": "EAA Intra-Fuel", "a_specs": "EAA 8g · ELECTROLYTE", "b_name": "Whey Isolate", "b_specs": "PRO 24g · NSF ✓" } },
        { "type": "phase", "settings": { "icon": "moon", "title": "Recovery", "a_name": "Magnesium Recovery", "a_specs": "MG 300mg · ZINC · B6", "b_name": "Slow Casein · Choc", "b_specs": "PRO 26g · NIGHT" } }
      ]
    }
  ]
}
{% endschema %}
