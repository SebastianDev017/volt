{%- liquid
  assign wordmark = settings.footer_wordmark_text | default: shop.name
-%}
<footer class="volt-footer">
  <div class="volt-footer__wordmark" aria-hidden="true">{{ wordmark }}</div>
  <div class="volt-footer__inner">
    <div class="volt-footer__cols">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand' -%}
            <div class="volt-footer__brand" {{ block.shopify_attributes }}>
              <div class="volt-footer__logo">{{ wordmark }}</div>
              {%- if block.settings.tagline != blank -%}<p class="volt-footer__tagline">{{ block.settings.tagline }}</p>{%- endif -%}
              {%- assign has_social = false -%}
              {%- if block.settings.instagram != blank or block.settings.youtube != blank or block.settings.tiktok != blank or block.settings.strava != blank -%}{%- assign has_social = true -%}{%- endif -%}
              {%- if has_social -%}
                <div class="volt-footer__social">
                  {%- if block.settings.instagram != blank -%}<a href="{{ block.settings.instagram }}" aria-label="Instagram">Instagram</a>{%- endif -%}
                  {%- if block.settings.youtube != blank -%}<a href="{{ block.settings.youtube }}" aria-label="YouTube">YouTube</a>{%- endif -%}
                  {%- if block.settings.tiktok != blank -%}<a href="{{ block.settings.tiktok }}" aria-label="TikTok">TikTok</a>{%- endif -%}
                  {%- if block.settings.strava != blank -%}<a href="{{ block.settings.strava }}" aria-label="Strava">Strava</a>{%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- when 'menu' -%}
            <div class="volt-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}<div class="volt-footer__heading">{{ block.settings.title }}</div>{%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="volt-footer__list">
                  {%- for l in linklists[block.settings.menu].links -%}<li><a href="{{ l.url }}">{{ l.title }}</a></li>{%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="volt-footer__trust">
      <span><i>&#9670;</i>{{ 'sections.footer_main.trust_secure' | t: default: 'Secure Checkout' }}</span>
      <span><i>&#9670;</i>{{ 'sections.footer_main.trust_shipping' | t: default: 'Free Shipping $75+' }}</span>
      <span><i>&#9670;</i>{{ 'sections.footer_main.trust_returns' | t: default: '30-Day Returns' }}</span>
      <span><i>&#9670;</i>{{ 'sections.footer_main.trust_nsf' | t: default: 'NSF Certified' }}</span>
    </div>

    <div class="volt-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright }}</span>
      {%- if section.settings.presets_line != blank -%}<span>{{ section.settings.presets_line }}</span>{%- endif -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  .volt-footer { background: var(--color-ink); color: var(--color-bg); position: relative; overflow: hidden; }
  .volt-footer__wordmark { position: absolute; left: 0; right: 0; bottom: -2.2vw; font-family: var(--font-display); font-weight: 800; font-size: 23vw; line-height: .7; letter-spacing: -.03em; color: var(--color-bg); opacity: var(--wordmark-opacity); text-align: center; pointer-events: none; user-select: none; }
  .volt-footer__inner { max-width: var(--page-width); margin-inline: auto; padding: 72px 28px 0; position: relative; }
  .volt-footer__cols { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 40px; }
  .volt-footer__logo { font-family: var(--font-display); font-weight: 800; font-size: 28px; letter-spacing: -.02em; }
  .volt-footer__tagline { font-size: 14px; line-height: 1.6; color: rgba(240,238,234,.6); max-width: 34ch; margin: 18px 0 0; }
  .volt-footer__social { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 18px; }
  .volt-footer__social a { font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; color: rgba(240,238,234,.7); text-decoration: none; }
  .volt-footer__social a:hover { color: var(--color-acid); }
  .volt-footer__heading { font-family: var(--font-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--color-acid); margin-bottom: 18px; }
  .volt-footer__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .volt-footer__list a { font-size: 14px; color: rgba(240,238,234,.75); text-decoration: none; }
  .volt-footer__list a:hover { color: var(--color-bg); }
  .volt-footer__trust { display: flex; flex-wrap: wrap; gap: 14px 28px; border-top: 1px solid rgba(240,238,234,.14); margin-top: 56px; padding: 22px 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: rgba(240,238,234,.6); }
  .volt-footer__trust span { display: flex; align-items: center; gap: 8px; }
  .volt-footer__trust i { color: var(--color-acid); font-style: normal; }
  .volt-footer__bottom { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 12px; padding: 18px 0 36px; font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em; color: rgba(240,238,234,.4); }
  @media (max-width: 860px) { .volt-footer__cols { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .volt-footer__cols { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    { "type": "text", "id": "copyright", "label": "t:sections.footer_main.copyright", "default": "VOLT Performance — a demo theme by Ruiz Digital" },
    { "type": "text", "id": "presets_line", "label": "t:sections.footer_main.presets_line", "default": "Volt / Anthracite / Titanium" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.footer_main.blocks.brand.name",
      "limit": 1,
      "settings": [
        { "type": "textarea", "id": "tagline", "label": "t:sections.footer_main.blocks.brand.tagline", "default": "Membership-first training. Track your strain, protect your recovery, gear the protocol." },
        { "type": "header", "content": "t:sections.footer_main.blocks.brand.social_header" },
        { "type": "url", "id": "instagram", "label": "t:sections.footer_main.blocks.brand.instagram" },
        { "type": "url", "id": "youtube", "label": "t:sections.footer_main.blocks.brand.youtube" },
        { "type": "url", "id": "tiktok", "label": "t:sections.footer_main.blocks.brand.tiktok" },
        { "type": "url", "id": "strava", "label": "t:sections.footer_main.blocks.brand.strava" }
      ]
    },
    {
      "type": "menu",
      "name": "t:sections.footer_main.blocks.menu.name",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "t:sections.footer_main.blocks.menu.title", "default": "Train" },
        { "type": "link_list", "id": "menu", "label": "t:sections.footer_main.blocks.menu.menu", "info": "t:sections.footer_main.blocks.menu.menu_info" }
      ]
    }
  ]
}
{% endschema %}
