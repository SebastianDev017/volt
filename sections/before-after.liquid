{% render 'section-style', section: section %}
<section class="volt-ba" data-animate>
  <div class="volt-ba__inner">
    <div class="volt-ba__head">
      {%- if section.settings.eyebrow != blank -%}<div class="volt-ba__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="volt-ba__title" {% render 'anim-attrs', value: section.settings.heading_animation, enabled: section.settings.enable_animations, delay_ms: section.settings.section_delay %}>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="volt-ba__grid">
      <before-after-slider class="volt-ba__viewer" style="--pos: 50%" {% render 'anim-attrs', value: section.settings.image_animation, enabled: section.settings.enable_animations %}>
        <div class="volt-ba__layer">
          {%- if section.settings.before_image != blank -%}
            {{ section.settings.before_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'volt-ba__img', alt: '' }}
          {%- else -%}{{ 'lifestyle-1' | placeholder_svg_tag: 'volt-ba__img' }}{%- endif -%}
          <span class="volt-ba__tag volt-ba__tag--before">{{ section.settings.before_label }}</span>
        </div>
        <div class="volt-ba__layer volt-ba__after">
          {%- if section.settings.after_image != blank -%}
            {{ section.settings.after_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'volt-ba__img', alt: '' }}
          {%- else -%}{{ 'lifestyle-2' | placeholder_svg_tag: 'volt-ba__img' }}{%- endif -%}
          <span class="volt-ba__tag volt-ba__tag--after">{{ section.settings.after_label }}</span>
        </div>
        <div class="volt-ba__handle" aria-hidden="true"><span>&larr; &rarr;</span></div>
        <input type="range" min="0" max="100" value="50" step="1" class="volt-ba__range" aria-label="{{ 'sections.before_after.range_label' | t: default: 'Drag to compare before and after' }}">
      </before-after-slider>

      <div class="volt-ba__story">
        {%- if section.settings.quote != blank -%}<p class="volt-ba__quote">{{ section.settings.quote }}</p>{%- endif -%}
        <div class="volt-ba__author">
          <div class="volt-ba__avatar">
            {%- if section.settings.author_avatar != blank -%}{{ section.settings.author_avatar | image_url: width: 84 | image_tag: loading: 'lazy', alt: '' }}{%- endif -%}
          </div>
          <div>
            <div class="volt-ba__name">{{ section.settings.author_name }}</div>
            <div class="volt-ba__meta">
              {%- if section.settings.author_tier != blank -%}<span class="volt-ba__tier">{{ section.settings.author_tier }}</span>{%- endif -%}
              {%- if section.settings.author_since != blank -%}<span class="volt-ba__since">{{ section.settings.author_since }}</span>{%- endif -%}
            </div>
          </div>
        </div>
        {%- if section.blocks.size > 0 -%}
          <div class="volt-ba__stats" {% render 'anim-attrs', value: section.settings.cards_animation, enabled: section.settings.enable_animations %}>
            {%- for block in section.blocks -%}
              <div class="volt-ba__stat" data-stagger-item {{ block.shopify_attributes }}>
                <div class="volt-ba__statval">{{ block.settings.value }}{%- if block.settings.unit != blank -%}<span>{{ block.settings.unit }}</span>{%- endif -%}</div>
                <div class="volt-ba__statlabel">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-ba { background: var(--color-ink); color: var(--color-bg); }
  .volt-ba__inner { max-width: var(--page-width); margin-inline: auto; padding: 104px 28px; }
  .volt-ba__head { text-align: center; margin-bottom: 40px; }
  .volt-ba__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-acid); }
  .volt-ba__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(35px, 3.45vw, 53px) * var(--section-heading-scale, 1)); line-height: 1.02; letter-spacing: -.01em; margin: 14px 0 0; color: var(--color-bg); }
  .volt-ba__grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 40px; align-items: center; }
  .volt-ba__viewer { position: relative; display: block; aspect-ratio: 4 / 3; overflow: hidden; border: 1px solid rgba(240,238,234,.16); touch-action: none; }
  .volt-ba__layer { position: absolute; inset: 0; }
  .volt-ba__after { clip-path: inset(0 0 0 var(--pos)); }
  .volt-ba__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .volt-ba__tag { position: absolute; bottom: 18px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; padding: 7px 11px; line-height: 1.5; }
  .volt-ba__tag--before { left: 18px; background: rgba(13,12,11,.7); color: var(--color-bg); }
  .volt-ba__tag--after { right: 18px; background: var(--color-acid); color: var(--color-ink); }
  .volt-ba__handle { position: absolute; top: 0; bottom: 0; left: var(--pos); width: 2px; background: var(--color-acid); transform: translateX(-50%); pointer-events: none; }
  .volt-ba__handle span { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); background: var(--color-acid); color: var(--color-ink); font-family: var(--font-mono); font-size: 12px; padding: 8px 12px; white-space: nowrap; font-weight: 500; }
  .volt-ba__range { position: absolute; inset: 0; width: 100%; height: 100%; margin: 0; opacity: 0; cursor: ew-resize; }
  .volt-ba__range:focus-visible { outline: 2px solid var(--color-acid); outline-offset: 2px; opacity: 1; }
  .volt-ba__story { display: flex; flex-direction: column; gap: 22px; }
  .volt-ba__quote { font-size: 17px; line-height: 1.6; color: rgba(240,238,234,.85); margin: 0; }
  .volt-ba__author { display: flex; align-items: center; gap: 12px; }
  .volt-ba__avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--color-surface); overflow: hidden; flex-shrink: 0; }
  .volt-ba__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .volt-ba__name { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--color-bg); }
  .volt-ba__meta { display: flex; align-items: center; gap: 8px; margin-top: 3px; }
  .volt-ba__tier { font-family: var(--font-mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; background: var(--color-acid); color: var(--color-ink); padding: 2px 6px; }
  .volt-ba__since { font-family: var(--font-mono); font-size: 10px; color: rgba(240,238,234,.5); }
  .volt-ba__stats { display: flex; gap: 20px; border-top: 1px solid rgba(240,238,234,.15); padding-top: 20px; }
  .volt-ba__statval { font-family: var(--font-display); font-weight: 800; font-size: 30px; color: var(--color-acid); line-height: 1; }
  .volt-ba__statval span { font-size: 15px; }
  .volt-ba__statlabel { font-family: var(--font-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: rgba(240,238,234,.5); margin-top: 6px; }
  @media (max-width: 860px) { .volt-ba__grid { grid-template-columns: 1fr; gap: 28px; } }
{% endstylesheet %}

<script>
  if (!customElements.get('before-after-slider')) {
    customElements.define('before-after-slider', class extends HTMLElement {
      connectedCallback() {
        this.range = this.querySelector('.volt-ba__range');
        if (!this.range) return;
        this.update = () => this.style.setProperty('--pos', this.range.value + '%');
        this.range.addEventListener('input', this.update);
        this.update();
      }
    });
  }
</script>

