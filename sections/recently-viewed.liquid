<recently-viewed
  class="volt-rv"
  data-exclude="{% if product != blank %}{{ product.handle }}{% endif %}"
  data-max="{{ section.settings.max_items | default: 6 }}"
  hidden
>
  <div class="volt-rv__inner">
    <div class="volt-rv__eyebrow">{{ section.settings.heading | default: 'Recently viewed' }}</div>
    <div class="volt-rv__grid" data-rv-grid style="--rv-cols: {{ section.settings.max_items | default: 6 }}"></div>
  </div>
</recently-viewed>

{% stylesheet %}
  .volt-rv { display: block; }
  .volt-rv[hidden] { display: none; }
  .volt-rv__inner { max-width: var(--page-width); margin-inline: auto; padding: clamp(40px, 6vw, 72px) 28px; }
  .volt-rv__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); margin-bottom: 22px; }
  .volt-rv__grid { display: grid; grid-template-columns: repeat(var(--rv-cols, 6), 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .volt-rv__card { display: flex; flex-direction: column; background: var(--color-bg); text-decoration: none; color: var(--color-ink); opacity: 0; transform: translateY(12px); }
  .volt-rv.is-ready .volt-rv__card { animation: volt-rv-in .5s var(--ease) forwards; animation-delay: calc(var(--i, 0) * .06s); }
  .volt-rv__media { aspect-ratio: 1 / 1; background: var(--color-surface); overflow: hidden; }
  .volt-rv__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
  .volt-rv__card:hover .volt-rv__media img { transform: scale(1.04); }
  .volt-rv__title { font-family: var(--font-display); font-weight: 700; font-size: 13px; line-height: 1.15; padding: 12px 12px 4px; }
  .volt-rv__price { font-family: var(--font-mono); font-size: 12px; color: var(--color-mid); padding: 0 12px 14px; }
  @keyframes volt-rv-in { to { opacity: 1; transform: none; } }
  @media (max-width: 1080px) { .volt-rv__grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 680px) { .volt-rv__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (prefers-reduced-motion: reduce) { .volt-rv__card { opacity: 1; transform: none; animation: none; } }
{% endstylesheet %}

<script>
  if (!customElements.get('recently-viewed')) {
    customElements.define('recently-viewed', class extends HTMLElement {
      connectedCallback() {
        var grid = this.querySelector('[data-rv-grid]');
        if (!grid) return;
        var exclude = this.dataset.exclude || '';
        var max = parseInt(this.dataset.max || '6', 10);
        var handles = [];
        try { handles = JSON.parse(localStorage.getItem('volt-recently-viewed') || '[]'); } catch (e) { handles = []; }
        handles = handles.filter(function (h) { return h && h !== exclude; }).slice(0, max);
        if (!handles.length) return;
        var money = function (c) {
          try { return new Intl.NumberFormat(document.documentElement.lang || 'en', { style: 'currency', currency: (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD' }).format(c / 100); }
          catch (e) { return '$' + (c / 100).toFixed(2); }
        };
        var esc = function (s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (m) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]; }); };
        var self = this;
        Promise.all(handles.map(function (h) {
          return fetch('/products/' + h + '.js').then(function (r) { return r.ok ? r.json() : null; }).catch(function () { return null; });
        })).then(function (items) {
          items = items.filter(Boolean);
          if (!items.length) return;
          grid.innerHTML = items.map(function (p, i) {
            var img = p.featured_image || (p.images && p.images[0]) || '';
            return '<a class="volt-rv__card" href="' + esc(p.url) + '" style="--i:' + i + '">' +
              '<div class="volt-rv__media">' + (img ? '<img src="' + esc(img) + '" alt="' + esc(p.title) + '" loading="lazy">' : '') + '</div>' +
              '<div class="volt-rv__title">' + esc(p.title) + '</div>' +
              '<div class="volt-rv__price">' + money(p.price) + '</div></a>';
          }).join('');
          self.hidden = false;
          requestAnimationFrame(function () { self.classList.add('is-ready'); });
        });
      }
    });
  }
</script>

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.recently_viewed.heading", "default": "Recently viewed" },
    { "type": "range", "id": "max_items", "min": 3, "max": 8, "step": 1, "label": "t:sections.recently_viewed.max_items", "default": 6 }
  ],
  "presets": [
    { "name": "t:sections.recently_viewed.name" }
  ]
}
{% endschema %}
