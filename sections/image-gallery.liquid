{% render 'section-style', section: section %}
{%- liquid
  assign layout = section.settings.layout
  assign cols = section.settings.columns
  assign gap = section.settings.gap
-%}
<section class="volt-gallery" data-animate>
  <div class="volt-gallery__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="volt-gallery__head">
        {%- if section.settings.eyebrow != blank -%}<div class="volt-gallery__eyebrow eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="volt-gallery__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="volt-gallery__wrap volt-gallery__wrap--{{ layout }}"
        data-stagger-group
        data-stagger-dir="scale"
        style="--cols: {{ cols }}; --gap: {{ gap }}px;"
      >
        {%- for block in section.blocks -%}
          <div class="volt-gallery__item" data-stagger-item {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a class="volt-gallery__link" href="{{ block.settings.link }}"{% if block.settings.caption != blank %} aria-label="{{ block.settings.caption | escape }}"{% endif %}>
            {%- endif -%}
            <figure class="volt-gallery__figure">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '300,500,700,900', class: 'volt-gallery__img', alt: block.settings.caption | escape }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'volt-gallery__img' }}
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <figcaption class="volt-gallery__caption">{{ block.settings.caption }}</figcaption>
              {%- endif -%}
            </figure>
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .volt-gallery { background: var(--color-bg); border-top: 1px solid var(--color-border); }
  .volt-gallery__inner { max-width: var(--page-width); margin-inline: auto; padding: calc(clamp(48px, 7vw, 84px) + 20px) 28px; }
  .volt-gallery__head { margin-bottom: clamp(28px, 4vw, 48px); }
  .volt-gallery__eyebrow { color: var(--color-mid); }
  .volt-gallery__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(35px, 3.45vw, 53px) * var(--section-heading-scale, 1)); line-height: 1.02; letter-spacing: -.01em; margin: 14px 0 0; }

  /* masonry layout — CSS columns */
  .volt-gallery__wrap--masonry { columns: var(--cols); column-gap: var(--gap); }
  .volt-gallery__wrap--masonry .volt-gallery__item { break-inside: avoid; margin-bottom: var(--gap); }

  /* grid layout — equal cells */
  .volt-gallery__wrap--grid { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: var(--gap); }
  .volt-gallery__wrap--grid .volt-gallery__figure { aspect-ratio: 1 / 1; }
  .volt-gallery__wrap--grid .volt-gallery__img { width: 100%; height: 100%; object-fit: cover; }

  .volt-gallery__item { position: relative; }
  .volt-gallery__link { display: block; color: inherit; }
  .volt-gallery__link .volt-gallery__img { transition: transform var(--dur-slow) var(--ease); }
  .volt-gallery__link:hover .volt-gallery__img,
  .volt-gallery__link:focus-visible .volt-gallery__img { transform: scale(1.04); transition-delay: .08s; }
  .volt-gallery__figure { position: relative; margin: 0; overflow: hidden; background: var(--color-surface); }
  .volt-gallery__img { width: 100%; height: auto; display: block; }

  .volt-gallery__caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--color-bg); background: linear-gradient(to top, rgba(13,12,11,0.78), rgba(13,12,11,0));
    padding: 18px 14px 12px;
    opacity: 0; transition: opacity var(--dur-med) var(--ease);
  }
  .volt-gallery__figure:hover .volt-gallery__caption,
  .volt-gallery__link:focus-visible .volt-gallery__caption { opacity: 1; }
  .volt-gallery__figure:hover .volt-gallery__caption { transition-delay: .08s; }

  @media (max-width: 860px) {
    .volt-gallery__wrap--masonry { columns: 2; }
    .volt-gallery__wrap--grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .volt-gallery__wrap--masonry { columns: 1; }
    .volt-gallery__wrap--grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.image_gallery.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "text", "id": "eyebrow", "label": "t:sections.image_gallery.eyebrow", "default": "// Gallery" },
    { "type": "text", "id": "heading", "label": "t:sections.image_gallery.heading", "default": "In the field." },
    { "type": "select", "id": "layout", "label": "t:sections.image_gallery.layout", "default": "masonry", "options": [
      { "value": "masonry", "label": "t:sections.image_gallery.layout_masonry" },
      { "value": "grid", "label": "t:sections.image_gallery.layout_grid" }
    ] },
    { "type": "range", "id": "columns", "label": "t:sections.image_gallery.columns", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "gap", "label": "t:sections.image_gallery.gap", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 8 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.image_gallery.blocks.image.name",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.image_gallery.blocks.image.image" },
        { "type": "text", "id": "caption", "label": "t:sections.image_gallery.blocks.image.caption" },
        { "type": "url", "id": "link", "label": "t:sections.image_gallery.blocks.image.link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_gallery.name",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
