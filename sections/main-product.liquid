{%- liquid
  assign p = product
  assign v = p.selected_or_first_available_variant
  assign member = p.price | times: 0.8
  assign sp = p.metafields.volt.specs.value
-%}
<section class="volt-pdp" data-animate>
  <div class="volt-pdp__crumbs">
    <a href="{{ routes.root_url }}">Shop</a><span>/</span>
    {%- if p.collections.first != blank -%}<a href="{{ p.collections.first.url }}">{{ p.collections.first.title }}</a><span>/</span>{%- endif -%}
    <span class="volt-pdp__crumbcur">{{ p.title }}</span>
  </div>

  <product-info class="volt-pdp__wrap" data-url="{{ p.url }}">
    <script type="application/json" data-pdp-variants>{{ p.variants | json }}</script>

    <div class="volt-pdp__grid">
      {%- comment -%} GALLERY {%- endcomment -%}
      <div class="volt-pdp__gallery">
        <div class="volt-pdp__main">
          {%- if p.featured_image -%}
            {{ p.featured_image | image_url: width: 1000 | image_tag: loading: 'eager', widths: '500, 700, 1000', class: 'volt-pdp__mainimg', data-pdp-main: '', alt: p.featured_image.alt | default: p.title | escape }}
          {%- else -%}{{ 'product-1' | placeholder_svg_tag: 'volt-pdp__mainimg' }}{%- endif -%}
          {%- if settings.show_member_price -%}<span class="volt-pdp__memberpill">Member &minus;20%</span>{%- endif -%}
        </div>
        {%- if p.images.size > 1 -%}
          <div class="volt-pdp__thumbs">
            {%- for img in p.images limit: 5 -%}
              <button type="button" class="volt-pdp__thumb{% if forloop.first %} is-active{% endif %}" data-pdp-thumb data-img="{{ img | image_url: width: 1000 }}">
                {{ img | image_url: width: 200 | image_tag: loading: 'lazy', alt: '' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} INFO {%- endcomment -%}
      <div class="volt-pdp__info">
        {%- if p.metafields.volt.category != blank -%}<span class="volt-pdp__cat">{{ p.metafields.volt.category }}</span>{%- endif -%}
        <h1 class="volt-pdp__title">{{ p.title }}</h1>
        {%- if p.vendor != blank -%}<div class="volt-pdp__sub">{{ p.vendor }}</div>{%- endif -%}

        {%- if section.settings.show_rating and section.settings.rating != blank -%}
          <div class="volt-pdp__rating"><span class="volt-pdp__stars">★★★★★</span><span>{{ section.settings.rating }}</span>{%- if section.settings.review_count != blank -%}<span class="volt-pdp__revcount">· {{ section.settings.review_count }} reviews</span>{%- endif -%}</div>
        {%- endif -%}

        <div class="volt-pdp__pricerow">
          <span class="volt-pdp__price" data-pdp-price>{{ p.price | money }}</span>
          {%- if settings.show_member_price -%}<span class="volt-pdp__mprice">{{ member | money }} member</span>{%- endif -%}
          {%- if p.compare_at_price > p.price -%}<span class="volt-pdp__compare" data-pdp-compare>{{ p.compare_at_price | money }}</span>{%- endif -%}
        </div>
        {%- capture specline -%}{%- if sp.protein != blank %}PRO {{ sp.protein }}{% endif %}{%- if sp.carbs != blank %} · CARBS {{ sp.carbs }}{% endif %}{%- if sp.fat != blank %} · FAT {{ sp.fat }}{% endif %}{%- if sp.cert != blank %} · {{ sp.cert }}{% endif %}{%- endcapture -%}
        {%- assign specline = specline | strip -%}
        {%- if specline != blank -%}<div class="volt-pdp__specs">{{ specline }}</div>{%- endif -%}

        {%- form 'product', p, id: 'pdp-form', class: 'volt-pdp__form' -%}
          <input type="hidden" name="id" value="{{ v.id }}" data-pdp-id>

          {%- unless p.has_only_default_variant -%}
            <div class="volt-pdp__opts">
              {%- for option in p.options_with_values -%}
                <label class="volt-pdp__optlabel" for="opt-pdp-{{ forloop.index0 }}">{{ option.name }}</label>
                <select id="opt-pdp-{{ forloop.index0 }}" class="volt-pdp__select" data-pdp-option="{{ forloop.index0 }}">
                  {%- for value in option.values -%}<option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>{%- endfor -%}
                </select>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          {%- if p.selling_plan_groups.size > 0 -%}
            <div class="volt-pdp__plans">
              <div class="volt-pdp__planslabel">Purchase options</div>
              <label class="volt-pdp__plan">
                <input type="radio" name="selling_plan" value="" checked>
                <span class="volt-pdp__plandot"></span>
                <span class="volt-pdp__planbody"><span class="volt-pdp__planname">One-time purchase</span><span class="volt-pdp__plansub">Ship once</span></span>
              </label>
              {%- for group in p.selling_plan_groups -%}
                {%- for plan in group.selling_plans -%}
                  <label class="volt-pdp__plan">
                    <input type="radio" name="selling_plan" value="{{ plan.id }}">
                    <span class="volt-pdp__plandot"></span>
                    <span class="volt-pdp__planbody"><span class="volt-pdp__planname">{{ plan.name }}</span>{%- if plan.description != blank -%}<span class="volt-pdp__plansub">{{ plan.description }}</span>{%- endif -%}</span>
                    {%- if group.name contains '%' or plan.name contains '%' -%}<span class="volt-pdp__plansave">Save</span>{%- endif -%}
                  </label>
                {%- endfor -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="volt-pdp__buy">
            <div class="volt-pdp__qty">
              <button type="button" data-pdp-dec aria-label="Decrease quantity">&minus;</button>
              <input type="number" name="quantity" value="1" min="1" data-pdp-qty aria-label="Quantity">
              <button type="button" data-pdp-inc aria-label="Increase quantity">+</button>
            </div>
            <button type="submit" name="add" class="volt-pdp__add"{% unless p.available %} disabled{% endunless %} data-pdp-add>
              {%- if p.available -%}Add to Cart{%- else -%}Sold out{%- endif -%}
            </button>
          </div>

          <div class="volt-pdp__trust">
            <span><i>&#9670;</i> Free shipping $75+</span><span><i>&#9670;</i> 30-day guarantee</span><span><i>&#9670;</i> NSF certified</span>
          </div>
        {%- endform -%}

        {%- if p.description != blank -%}<div class="volt-pdp__desc rte">{{ p.description }}</div>{%- endif -%}
      </div>
    </div>

    {%- comment -%} NUTRITION PANEL (radio-driven tabs) {%- endcomment -%}
    {%- assign macros = section.blocks | where: 'type', 'macro' -%}
    {%- if macros.size > 0 or section.settings.ingredients != blank -%}
      <div class="volt-nut">
        <input type="radio" name="nut-pdp" id="nut-facts-pdp" class="visually-hidden" checked>
        <input type="radio" name="nut-pdp" id="nut-ingr-pdp" class="visually-hidden">
        <input type="radio" name="nut-pdp" id="nut-certs-pdp" class="visually-hidden">
        <div class="volt-nut__tabs">
          <label for="nut-facts-pdp">Nutrition facts</label>
          <label for="nut-ingr-pdp">Ingredients</label>
          <label for="nut-certs-pdp">Certifications</label>
        </div>
        <div class="volt-nut__panels">
          <div class="volt-nut__panel volt-nut__panel--facts">
            <div class="volt-nut__facts">
              <div class="volt-nut__factshead">
                <span>Per serving{% if section.settings.serving != blank %} · {{ section.settings.serving }}{% endif %}</span>
                {%- if section.settings.calories != blank -%}<span class="volt-nut__kcal">{{ section.settings.calories }}<small> kcal</small></span>{%- endif -%}
              </div>
              <div class="volt-nut__macros">
                {%- for block in macros -%}
                  <div class="volt-nut__macro" {{ block.shopify_attributes }}>
                    <div class="volt-nut__macrohead"><span>{{ block.settings.label }}</span><span>{{ block.settings.value }}</span></div>
                    <div class="volt-nut__bar"><span style="width: {{ block.settings.fill | at_most: 100 }}%;{% if block.settings.accent %}background:var(--color-acid);{% endif %}"></span></div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
          <div class="volt-nut__panel volt-nut__panel--ingr">
            {%- if section.settings.ingredients != blank -%}<div class="rte">{{ section.settings.ingredients }}</div>{%- else -%}<p class="volt-nut__empty">Ingredient information coming soon.</p>{%- endif -%}
          </div>
          <div class="volt-nut__panel volt-nut__panel--certs">
            <div class="volt-nut__certs">
              <div class="volt-nut__cert"><span class="volt-nut__certmark">NSF</span><div>Certified for Sport®<br>Lot-tested for banned substances</div></div>
              <div class="volt-nut__cert"><span class="volt-nut__certmark">INFORMED</span><div>Informed Sport<br>Every batch screened</div></div>
              <div class="volt-nut__cert"><span class="volt-nut__certmark">3RD-PARTY</span><div>Independent lab<br>Heavy-metal tested</div></div>
            </div>
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} FAQ {%- endcomment -%}
    {%- assign faqs = section.blocks | where: 'type', 'faq' -%}
    {%- if faqs.size > 0 -%}
      <div class="volt-pdp__faq">
        <h2 class="volt-pdp__faqtitle">Details</h2>
        {%- for block in faqs -%}
          <details class="volt-pdp__faqitem" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}<span class="volt-pdp__faqicon">+</span></summary>
            <div class="volt-pdp__faqbody rte">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} RECOMMENDATIONS {%- endcomment -%}
    {%- assign rec = section.settings.recommendations_collection -%}
    {%- if rec == blank -%}{%- assign rec = p.collections.first -%}{%- endif -%}
    {%- if rec != blank and rec.products.size > 1 -%}
      <div class="volt-pdp__recs">
        <div class="volt-pdp__receyebrow">{{ section.settings.recommendations_eyebrow }}</div>
        <h2 class="volt-pdp__rectitle">{{ section.settings.recommendations_heading }}</h2>
        <div class="volt-pdp__recgrid">
          {%- assign shown = 0 -%}
          {%- for rp in rec.products -%}
            {%- if rp.id != p.id and shown < 4 -%}{% render 'product-card', card_product: rp %}{%- assign shown = shown | plus: 1 -%}{%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </product-info>

  {%- comment -%} STICKY BUY BAR (mobile) {%- endcomment -%}
  <div class="volt-pdp__sticky">
    <div class="volt-pdp__stickyprice"><span>{{ p.price | money }}</span><small>{% if settings.show_member_price %}Member{% else %}Price{% endif %}</small></div>
    <button type="submit" form="pdp-form" name="add" class="volt-pdp__add"{% unless p.available %} disabled{% endunless %}>{% if p.available %}Add to Cart{% else %}Sold out{% endif %}</button>
  </div>
</section>

{% stylesheet %}
  .volt-pdp { max-width: var(--page-width); margin-inline: auto; padding: 20px 28px 70px; }
  .volt-pdp__crumbs { display: flex; gap: 8px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; color: var(--color-mid); padding-bottom: 20px; }
  .volt-pdp__crumbs a { color: var(--color-mid); text-decoration: none; }
  .volt-pdp__crumbs a:hover { color: var(--color-ink); }
  .volt-pdp__crumbcur { color: var(--color-ink); }
  .volt-pdp__wrap { display: block; }
  .volt-pdp__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }

  .volt-pdp__main { position: relative; aspect-ratio: 1/1; background: var(--color-surface); border: 1px solid var(--color-border); overflow: hidden; }
  .volt-pdp__mainimg { width: 100%; height: 100%; object-fit: cover; }
  .volt-pdp__memberpill { position: absolute; top: 0; right: 0; z-index: 2; font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; background: var(--color-acid); color: var(--color-ink); padding: 6px 11px; }
  .volt-pdp__thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px; }
  .volt-pdp__thumb { aspect-ratio: 1/1; background: var(--color-surface); border: 1px solid var(--color-border); padding: 0; cursor: pointer; overflow: hidden; }
  .volt-pdp__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .volt-pdp__thumb.is-active { border-color: var(--color-ink); }

  .volt-pdp__cat { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  .volt-pdp__title { font-family: var(--font-display); font-weight: 800; font-size: clamp(32px, 3.4vw, 46px); line-height: 1.02; letter-spacing: -.01em; margin: 10px 0 0; }
  .volt-pdp__sub { font-family: var(--font-display); font-weight: 500; font-size: 15px; color: var(--color-mid); margin-top: 4px; }
  .volt-pdp__rating { display: flex; align-items: center; gap: 10px; margin-top: 14px; font-family: var(--font-mono); font-size: 12px; color: var(--color-ink); }
  .volt-pdp__stars { color: var(--color-acid); letter-spacing: 1px; }
  .volt-pdp__revcount { color: var(--color-mid); }
  .volt-pdp__pricerow { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin: 22px 0 6px; }
  .volt-pdp__price { font-family: var(--font-display); font-weight: 800; font-size: 36px; line-height: 1; }
  .volt-pdp__mprice { font-family: var(--font-mono); font-size: 11px; background: var(--color-acid); color: var(--color-ink); padding: 3px 7px; }
  .volt-pdp__compare { font-family: var(--font-mono); font-size: 15px; color: var(--color-mid); text-decoration: line-through; }
  .volt-pdp__specs { font-family: var(--font-mono); font-size: 11px; color: var(--color-mid); letter-spacing: .04em; }

  .volt-pdp__form { margin: 0; }
  .volt-pdp__opts { margin-top: 24px; display: flex; flex-direction: column; gap: 8px; }
  .volt-pdp__optlabel { font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--color-mid); }
  .volt-pdp__select { width: 100%; background: var(--color-bg); color: var(--color-ink); border: 1px solid var(--color-ink); border-radius: 0; padding: 13px 14px; font-family: var(--font-body); font-size: 14px; }

  .volt-pdp__plans { margin-top: 26px; display: flex; flex-direction: column; gap: 10px; }
  .volt-pdp__planslabel { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); }
  .volt-pdp__plan { display: flex; align-items: center; gap: 14px; border: 1px solid var(--color-border); padding: 15px 16px; cursor: pointer; }
  .volt-pdp__plan:has(input:checked) { border-color: var(--color-ink); }
  .volt-pdp__plan input { position: absolute; opacity: 0; width: 0; height: 0; }
  .volt-pdp__plandot { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--color-mid); flex-shrink: 0; display: grid; place-items: center; }
  .volt-pdp__plan:has(input:checked) .volt-pdp__plandot { border-color: var(--color-ink); }
  .volt-pdp__plan:has(input:checked) .volt-pdp__plandot::after { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--color-acid); }
  .volt-pdp__planbody { flex: 1; }
  .volt-pdp__planname { font-family: var(--font-display); font-weight: 700; font-size: 15px; display: block; }
  .volt-pdp__plansub { font-family: var(--font-mono); font-size: 11px; color: var(--color-mid); }
  .volt-pdp__plansave { font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em; background: var(--color-acid); color: var(--color-ink); padding: 4px 8px; }

  .volt-pdp__buy { display: flex; gap: 12px; margin-top: 22px; }
  .volt-pdp__qty { display: flex; align-items: center; border: 1px solid var(--color-ink); }
  .volt-pdp__qty button { background: none; border: none; width: 46px; height: 52px; cursor: pointer; font-size: 18px; color: var(--color-ink); }
  .volt-pdp__qty input { width: 40px; height: 52px; text-align: center; border: 0; background: none; font-family: var(--font-mono); font-size: 15px; color: var(--color-ink); -moz-appearance: textfield; }
  .volt-pdp__qty input::-webkit-outer-spin-button, .volt-pdp__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .volt-pdp__add { flex: 1; background: var(--color-acid); border: none; color: var(--color-ink); font-family: var(--font-body); font-weight: 500; font-size: 14px; letter-spacing: .05em; text-transform: uppercase; cursor: pointer; padding: 16px; }
  .volt-pdp__add[disabled] { background: var(--color-border); color: var(--color-mid); cursor: not-allowed; }
  .volt-pdp__trust { display: flex; gap: 18px; flex-wrap: wrap; margin-top: 18px; font-family: var(--font-mono); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--color-mid); }
  .volt-pdp__trust i { color: var(--color-acid); font-style: normal; }
  .volt-pdp__desc { font-size: 15px; line-height: 1.65; color: var(--color-mid); margin-top: 24px; border-top: 1px solid var(--color-border); padding-top: 22px; }

  .volt-nut { border: 1px solid var(--color-border); margin-top: 64px; }
  .volt-nut__tabs { display: flex; border-bottom: 1px solid var(--color-border); flex-wrap: wrap; }
  .volt-nut__tabs label { flex: 1; min-width: 140px; text-align: center; cursor: pointer; font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--color-mid); padding: 18px 16px; border-bottom: 2px solid transparent; }
  #nut-facts-pdp:checked ~ .volt-nut__tabs label[for="nut-facts-pdp"],
  #nut-ingr-pdp:checked ~ .volt-nut__tabs label[for="nut-ingr-pdp"],
  #nut-certs-pdp:checked ~ .volt-nut__tabs label[for="nut-certs-pdp"] { color: var(--color-ink); border-bottom-color: var(--color-acid); }
  .volt-nut__panels { padding: 34px 32px; }
  .volt-nut__panel { display: none; }
  #nut-facts-pdp:checked ~ .volt-nut__panels .volt-nut__panel--facts,
  #nut-ingr-pdp:checked ~ .volt-nut__panels .volt-nut__panel--ingr,
  #nut-certs-pdp:checked ~ .volt-nut__panels .volt-nut__panel--certs { display: block; }
  .volt-nut__factshead { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 2px solid var(--color-ink); padding-bottom: 10px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--color-mid); }
  .volt-nut__kcal { font-family: var(--font-display); font-weight: 800; font-size: 28px; color: var(--color-ink); }
  .volt-nut__kcal small { font-family: var(--font-mono); font-size: 13px; font-weight: 400; color: var(--color-mid); }
  .volt-nut__macros { display: flex; flex-direction: column; gap: 16px; margin-top: 22px; max-width: 560px; }
  .volt-nut__macrohead { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 12px; margin-bottom: 7px; }
  .volt-nut__bar { height: 8px; background: var(--color-surface); }
  .volt-nut__bar span { display: block; height: 100%; background: var(--color-ink); }
  .volt-nut__macro:first-child .volt-nut__bar span { background: var(--color-acid); }
  .volt-nut__certs { display: flex; gap: 16px; flex-wrap: wrap; }
  .volt-nut__cert { border: 1px solid var(--color-border); padding: 20px 24px; display: flex; align-items: center; gap: 14px; flex: 1; min-width: 200px; font-family: var(--font-mono); font-size: 11px; color: var(--color-mid); line-height: 1.5; }
  .volt-nut__certmark { font-family: var(--font-display); font-weight: 800; font-size: 18px; color: var(--color-acid); }
  .volt-nut__empty { color: var(--color-mid); }

  .volt-pdp__faq { max-width: 760px; margin: 64px auto 0; }
  .volt-pdp__faqtitle { font-family: var(--font-display); font-weight: 700; font-size: 26px; margin: 0 0 22px; }
  .volt-pdp__faqitem { border-bottom: 1px solid var(--color-border); }
  .volt-pdp__faqitem:first-child { border-top: 1px solid var(--color-border); }
  .volt-pdp__faqitem summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; padding: 20px 4px; font-family: var(--font-display); font-weight: 700; font-size: 16px; list-style: none; }
  .volt-pdp__faqitem summary::-webkit-details-marker { display: none; }
  .volt-pdp__faqicon { color: var(--color-acid); font-size: 20px; transition: transform var(--dur-fast) var(--ease); }
  .volt-pdp__faqitem[open] .volt-pdp__faqicon { transform: rotate(45deg); }
  .volt-pdp__faqbody { font-size: 14px; line-height: 1.65; color: var(--color-mid); padding: 0 4px 22px; max-width: 64ch; }

  .volt-pdp__recs { margin-top: 72px; }
  .volt-pdp__receyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); }
  .volt-pdp__rectitle { font-family: var(--font-display); font-weight: 700; font-size: clamp(26px, 2.6vw, 38px); margin: 12px 0 28px; }
  .volt-pdp__recgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }

  .volt-pdp__sticky { display: none; position: fixed; left: 0; right: 0; bottom: 0; z-index: 70; background: var(--color-bg); border-top: 1px solid var(--color-border); padding: 12px 16px; align-items: center; gap: 12px; box-shadow: 0 -8px 30px rgba(13,12,11,.12); }
  .volt-pdp__stickyprice { flex-shrink: 0; }
  .volt-pdp__stickyprice span { display: block; font-family: var(--font-display); font-weight: 800; font-size: 20px; line-height: 1; }
  .volt-pdp__stickyprice small { font-family: var(--font-mono); font-size: 9px; color: var(--color-mid); text-transform: uppercase; letter-spacing: .08em; }
  .volt-pdp__sticky .volt-pdp__add { flex: 1; padding: 14px; }

  @media (max-width: 860px) {
    .volt-pdp__grid { grid-template-columns: 1fr; gap: 28px; }
    .volt-pdp__recgrid { grid-template-columns: 1fr 1fr; }
    .volt-pdp__sticky { display: flex; }
  }
{% endstylesheet %}

<script>
  if (!customElements.get('product-info')) {
    customElements.define('product-info', class extends HTMLElement {
      connectedCallback() {
        var data = this.querySelector('[data-pdp-variants]');
        this.variants = data ? JSON.parse(data.textContent) : [];
        this.idInput = this.querySelector('[data-pdp-id]');
        this.priceEl = this.querySelector('[data-pdp-price]');
        this.addBtn = this.querySelector('[data-pdp-add]');
        this.opts = Array.from(this.querySelectorAll('[data-pdp-option]'));
        this.opts.forEach((s) => s.addEventListener('change', this.onVariant.bind(this)));
        var main = this.querySelector('[data-pdp-main]');
        this.querySelectorAll('[data-pdp-thumb]').forEach((t) => t.addEventListener('click', () => {
          if (main && t.dataset.img) main.src = t.dataset.img;
          this.querySelectorAll('[data-pdp-thumb]').forEach((x) => x.classList.remove('is-active'));
          t.classList.add('is-active');
        }));
        var dec = this.querySelector('[data-pdp-dec]'), inc = this.querySelector('[data-pdp-inc]'), qty = this.querySelector('[data-pdp-qty]');
        if (dec && qty) dec.addEventListener('click', () => { qty.value = Math.max(1, (parseInt(qty.value, 10) || 1) - 1); });
        if (inc && qty) inc.addEventListener('click', () => { qty.value = (parseInt(qty.value, 10) || 1) + 1; });
      }
      money(cents) {
        try { return new Intl.NumberFormat(document.documentElement.lang || 'en', { style: 'currency', currency: window.Shopify && Shopify.currency ? Shopify.currency.active : 'USD' }).format(cents / 100); }
        catch (e) { return '$' + (cents / 100).toFixed(2); }
      }
      onVariant() {
        var chosen = this.opts.map((s) => s.value);
        var match = this.variants.find((v) => JSON.stringify(v.options) === JSON.stringify(chosen));
        if (!match) return;
        if (this.idInput) this.idInput.value = match.id;
        if (this.priceEl) this.priceEl.textContent = this.money(match.price);
        if (this.addBtn) {
          this.addBtn.disabled = !match.available;
          this.addBtn.textContent = match.available ? 'Add to Cart' : 'Sold out';
        }
      }
    });
  }
</script>

