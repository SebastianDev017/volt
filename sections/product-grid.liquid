{%- liquid
  assign coll = section.settings.collection
  assign cols = section.settings.columns | default: 4
  assign limit = cols | times: 2
  assign radius = section.settings.image_radius | default: 0
-%}

<style>
  #shopify-section-{{ section.id }} .pgrid__grid{
    grid-template-columns: repeat({{ cols }}, minmax(0, 1fr));
  }
  @media (max-width: 989px){
    #shopify-section-{{ section.id }} .pgrid__grid{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 749px){
    #shopify-section-{{ section.id }} .pgrid__grid{ grid-template-columns: 1fr; }
  }
</style>

<section class="section pgrid" data-animate>
  <div class="section-inner">
    <div class="section-head">
      <div class="pgrid__head-left">
        {%- if section.settings.subtitle != blank -%}
          <p class="eyebrow">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="h2 pgrid__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and coll != blank -%}
        <a class="link-arrow pgrid__viewall" href="{{ coll.url }}">
          VIEW ALL
          <span aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}
    </div>

    {%- if coll != blank and coll.products.size > 0 -%}
      <div class="pgrid__grid">
        {%- for product in coll.products limit: limit -%}
          {% render 'product-card',
            card_product: product,
            image_radius: radius,
            hover_swap: section.settings.hover_swap,
            quick_buy: section.settings.quick_buy,
            stock_threshold: section.settings.stock_threshold,
            show_tasting_specs: section.settings.show_tasting_specs,
            show_member_price: section.settings.show_member_price
          %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="pgrid__empty card">
        <p class="muted">Select a collection to feature your products here.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .pgrid__title{ margin-top: 12px; }
  .pgrid__head-left{ max-width: 60ch; }
  .pgrid__empty{ padding: clamp(40px, 6vw, 72px); text-align: center; }

  .pgrid__grid{
    display: grid;
    gap: var(--gutter);
  }

  /* ---------- product card ---------- */
  .pcard{ display: flex; flex-direction: column; }

  .pcard__media{
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: var(--pcard-radius, 0);
  }

  .pcard__img{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--dur-med) var(--ease), transform var(--dur-slow) var(--ease);
  }
  .pcard__img--ph{
    background: linear-gradient(135deg, var(--color-surface), var(--color-border));
  }
  .pcard__media:hover .pcard__img--primary{ transform: scale(1.03); }

  .pcard__img--secondary{ opacity: 0; }
  .pcard__media:has(.pcard__img--secondary):hover .pcard__img--primary{ opacity: 0; }
  .pcard__media:has(.pcard__img--secondary):hover .pcard__img--secondary{ opacity: 1; transform: scale(1.03); }

  /* badges */
  .pcard__badges{
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .pcard__badges--tl{ top: 10px; left: 10px; }
  .pcard__badges--tr{ top: 10px; right: 10px; align-items: flex-end; }
  .pcard__stock{ align-self: flex-start; }

  /* quick add */
  .pcard__quickadd{
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    transform: translateY(100%);
    transition: transform var(--dur-med) var(--ease);
  }
  .pcard__media:hover .pcard__quickadd,
  .pcard__media:focus-within .pcard__quickadd{ transform: translateY(0); }
  .pcard__quickadd-btn{ font-size: 11px; padding-block: 14px; }
  .pcard__form, .pcard__form-el{ display: block; }

  /* body */
  .pcard__body{ padding-top: 16px; display: flex; flex-direction: column; gap: 8px; }

  .pcard__meta{
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .pcard__pill{
    display: inline-block;
    padding: 4px 8px;
    border: 1px solid var(--color-border);
    color: var(--color-ink);
  }
  .pcard__vendor{ letter-spacing: 0.12em; }

  .pcard__title{ font-size: clamp(16px, 1.4vw, 19px); line-height: 1.1; }
  .pcard__title a{ transition: color var(--dur-fast) var(--ease); }
  .pcard__title a:hover{ color: var(--color-mid); }

  .pcard__specs{ margin-top: 2px; }

  .pcard__pricing{
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: var(--font-display-weight-2);
    font-size: 16px;
    margin-top: 2px;
  }
  .pcard__price--sale{ color: var(--color-danger); }
  .pcard__price--was{ font-family: var(--font-mono); font-weight: 400; font-size: 12px; }

  .pcard__member{
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-success);
  }
  .pcard__member-label{ letter-spacing: 0.14em; }

  .pcard__sub{ margin-top: 4px; color: var(--color-ink); }

  /* ---------- responsive ---------- */
  @media (hover: none){
    .pcard__quickadd{ transform: translateY(0); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_grid.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.product_grid.title.label",
      "default": "Built for the protocol"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.product_grid.subtitle.label",
      "default": "Featured gear"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.product_grid.collection.label"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "t:sections.product_grid.columns.label",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.product_grid.show_view_all.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.product_grid.card_header.content"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "t:sections.product_grid.image_radius.label",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "hover_swap",
      "label": "t:sections.product_grid.hover_swap.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "quick_buy",
      "label": "t:sections.product_grid.quick_buy.label",
      "info": "t:sections.product_grid.quick_buy.info",
      "default": true
    },
    {
      "type": "range",
      "id": "stock_threshold",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "u",
      "label": "t:sections.product_grid.stock_threshold.label",
      "info": "t:sections.product_grid.stock_threshold.info",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_tasting_specs",
      "label": "t:sections.product_grid.show_tasting_specs.label",
      "info": "t:sections.product_grid.show_tasting_specs.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_member_price",
      "label": "t:sections.product_grid.show_member_price.label",
      "info": "t:sections.product_grid.show_member_price.info",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_grid.name"
    }
  ]
}
{% endschema %}
