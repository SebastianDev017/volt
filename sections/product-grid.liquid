{% render 'section-style', section: section %}
{%- liquid
  assign coll = section.settings.collection
  assign cols = section.settings.columns | default: 4
  assign lim = cols | times: 2
-%}
<section class="volt-grid" data-animate>
  <div class="volt-grid__inner">
    <div class="volt-grid__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<div class="volt-grid__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="volt-grid__title" {% render 'anim-attrs', value: section.settings.heading_animation, enabled: section.settings.enable_animations, delay_ms: section.settings.section_delay %}>{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.filter_menu != blank and linklists[section.settings.filter_menu].links.size > 0 -%}
        <div class="volt-grid__pills">
          {%- for link in linklists[section.settings.filter_menu].links -%}
            <a href="{{ link.url }}" class="volt-grid__pill">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- elsif section.settings.show_view_all and coll != blank -%}
        <a href="{{ coll.url }}" class="volt-grid__viewall">View all &rarr;</a>
      {%- endif -%}
    </div>
    <div class="volt-grid__grid" style="--cols: {{ cols }}" {% render 'anim-attrs', value: section.settings.cards_animation, enabled: section.settings.enable_animations %}>
      {%- assign promos = section.blocks | where: 'type', 'promo_tile' -%}
      {%- if coll != blank and coll.products.size > 0 -%}
        {%- for product in coll.products limit: lim -%}
          {%- assign idx = forloop.index -%}
          {%- for promo in promos -%}
            {%- if promo.settings.position == idx -%}
              <div class="volt-grid__promo volt-grid__promo--{{ promo.settings.color_scheme | default: 'ink' }}" data-stagger-item {{ promo.shopify_attributes }}{% if promo.settings.image != blank %} style="background-image: url({{ promo.settings.image | image_url: width: 900 }})"{% endif %}>
                <div class="volt-grid__promoinner">
                  {%- if promo.settings.heading != blank -%}<h3 class="volt-grid__promoheading">{{ promo.settings.heading }}</h3>{%- endif -%}
                  {%- if promo.settings.body != blank -%}<p class="volt-grid__promobody">{{ promo.settings.body }}</p>{%- endif -%}
                  {%- if promo.settings.cta_label != blank -%}<a href="{{ promo.settings.cta_url | default: '#' }}" class="volt-grid__promocta">{{ promo.settings.cta_label }} &rarr;</a>{%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
          {% render 'product-card', card_product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..lim) -%}
          {% render 'product-card', card_product: blank %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .volt-grid { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .volt-grid__inner { max-width: var(--page-width); margin-inline: auto; padding: 100px 28px; }
  .volt-grid__head { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 20px; margin-bottom: 32px; }
  .volt-grid__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); }
  .volt-grid__title { font-family: var(--font-display); font-weight: 800; font-size: calc(clamp(35px, 3.45vw, 53px) * var(--section-heading-scale, 1)); line-height: 1.02; letter-spacing: -.01em; margin: 14px 0 0; }
  .volt-grid__pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .volt-grid__pill { font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; padding: 9px 14px; border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-ink); text-decoration: none; transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease); }
  .volt-grid__pill:hover { background: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink); transition-delay: .03s; }
  .volt-grid__viewall { font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border-bottom: 2px solid var(--color-acid); padding-bottom: 3px; transition: color var(--dur-fast) var(--ease); }
  .volt-grid__viewall:hover, .volt-grid__viewall:focus-visible { color: var(--color-mid); transition-delay: .03s; }
  .volt-grid__grid { display: grid; grid-template-columns: repeat(var(--cols), 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .volt-grid__promo { position: relative; background-color: var(--color-ink); background-size: cover; background-position: center; min-height: 240px; display: flex; }
  .volt-grid__promo::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(13,12,11,.2), rgba(13,12,11,.75)); }
  .volt-grid__promo--ink { background-color: var(--color-ink); color: var(--color-bg); }
  .volt-grid__promo--acid { background-color: var(--color-acid); color: var(--color-ink); }
  .volt-grid__promo--acid::before { display: none; }
  .volt-grid__promo--default { background-color: var(--color-surface); color: var(--color-ink); }
  .volt-grid__promo--default::before { display: none; }
  .volt-grid__promoinner { position: relative; z-index: 1; padding: 28px; display: flex; flex-direction: column; justify-content: flex-end; gap: 10px; }
  .volt-grid__promoheading { font-family: var(--font-display); font-weight: 800; font-size: clamp(22px, 2vw, 30px); line-height: 1.02; margin: 0; }
  .volt-grid__promobody { font-size: 13px; line-height: 1.55; opacity: .92; margin: 0; }
  .volt-grid__promocta { font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; border-bottom: 2px solid var(--color-acid); padding-bottom: 2px; align-self: flex-start; transition: opacity var(--dur-fast) var(--ease); }
  .volt-grid__promocta:hover, .volt-grid__promocta:focus-visible { opacity: .7; transition-delay: .03s; }
  .volt-grid__promo--acid .volt-grid__promocta { border-bottom-color: var(--color-ink); }
  @media (max-width: 1080px) { .volt-grid__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .volt-grid__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_grid.name",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "t:sections.style.header" },
    { "type": "select", "id": "color_scheme", "label": "t:sections.style.color_scheme", "default": "inherit", "options": [
      { "value": "inherit", "label": "t:sections.style.scheme_inherit" },
      { "value": "volt", "label": "t:sections.style.scheme_volt" },
      { "value": "anthracite", "label": "t:sections.style.scheme_anthracite" },
      { "value": "titanium", "label": "t:sections.style.scheme_titanium" },
      { "value": "ink", "label": "t:sections.style.scheme_ink" },
      { "value": "acid", "label": "t:sections.style.scheme_acid" }
    ] },
    { "type": "select", "id": "heading_size", "label": "t:sections.style.heading_size", "default": "medium", "options": [
      { "value": "small", "label": "t:sections.style.size_small" },
      { "value": "medium", "label": "t:sections.style.size_medium" },
      { "value": "large", "label": "t:sections.style.size_large" },
      { "value": "xl", "label": "t:sections.style.size_xl" }
    ] },
    { "type": "color", "id": "heading_color", "label": "t:sections.style.heading_color" },
    { "type": "color", "id": "body_color", "label": "t:sections.style.body_color" },
    { "type": "select", "id": "button_style", "label": "t:sections.style.button_style", "default": "acid", "options": [
      { "value": "acid", "label": "t:sections.style.btn_acid" },
      { "value": "outline", "label": "t:sections.style.btn_outline" },
      { "value": "ghost", "label": "t:sections.style.btn_ghost" },
      { "value": "ink", "label": "t:sections.style.btn_ink" },
      { "value": "white", "label": "t:sections.style.btn_white" }
    ] },
    { "type": "checkbox", "id": "show_accent_rule", "label": "t:sections.style.show_accent_rule", "default": false },
    { "type": "text", "id": "eyebrow", "label": "t:sections.product_grid.eyebrow", "default": "// The Upsell" },
    { "type": "text", "id": "heading", "label": "t:sections.product_grid.heading", "default": "Gear the protocol." },
    { "type": "collection", "id": "collection", "label": "t:sections.product_grid.collection" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "t:sections.product_grid.columns", "default": 4 },
    { "type": "link_list", "id": "filter_menu", "label": "t:sections.product_grid.filter_menu", "info": "t:sections.product_grid.filter_menu_info" },
    { "type": "checkbox", "id": "show_view_all", "label": "t:sections.product_grid.show_view_all", "default": true },
    { "type": "header", "content": "t:sections.animation.header" },
    { "type": "checkbox", "id": "enable_animations", "label": "t:sections.animation.enable", "default": true },
    { "type": "select", "id": "heading_animation", "label": "t:sections.animation.heading", "default": "split-words", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "split-chars", "label": "t:sections.animation.opt_split_chars" },
      { "value": "split-words", "label": "t:sections.animation.opt_split_words" },
      { "value": "split-lines", "label": "t:sections.animation.opt_split_lines" },
      { "value": "fade-up", "label": "t:sections.animation.opt_fade_up" },
      { "value": "clip-bottom", "label": "t:sections.animation.opt_clip_bottom" },
      { "value": "clip-left", "label": "t:sections.animation.opt_clip_left" }
    ] },
    { "type": "select", "id": "cards_animation", "label": "t:sections.animation.cards", "default": "stagger-up", "options": [
      { "value": "none", "label": "t:sections.animation.opt_none" },
      { "value": "stagger-up", "label": "t:sections.animation.opt_stagger_up" },
      { "value": "stagger-fade", "label": "t:sections.animation.opt_stagger_fade" },
      { "value": "stagger-scale", "label": "t:sections.animation.opt_stagger_scale" },
      { "value": "stagger-rotate", "label": "t:sections.animation.opt_stagger_rotate" }
    ] },
    { "type": "range", "id": "section_delay", "label": "t:sections.animation.delay", "min": 0, "max": 800, "step": 50, "unit": "ms", "default": 0 }
  ],
  "blocks": [
    {
      "type": "promo_tile",
      "name": "t:sections.product_grid.blocks.promo_tile.name",
      "settings": [
        { "type": "range", "id": "position", "label": "t:sections.product_grid.blocks.promo_tile.position", "info": "t:sections.product_grid.blocks.promo_tile.position_info", "min": 1, "max": 8, "step": 1, "default": 3 },
        { "type": "image_picker", "id": "image", "label": "t:sections.product_grid.blocks.promo_tile.image" },
        { "type": "select", "id": "color_scheme", "label": "t:sections.product_grid.blocks.promo_tile.color_scheme", "default": "ink", "options": [
          { "value": "ink", "label": "t:sections.product_grid.blocks.promo_tile.scheme_ink" },
          { "value": "acid", "label": "t:sections.product_grid.blocks.promo_tile.scheme_acid" },
          { "value": "default", "label": "t:sections.product_grid.blocks.promo_tile.scheme_default" }
        ] },
        { "type": "text", "id": "heading", "label": "t:sections.product_grid.blocks.promo_tile.heading", "default": "New batch live" },
        { "type": "textarea", "id": "body", "label": "t:sections.product_grid.blocks.promo_tile.body", "default": "Fresh drop, member pricing inside." },
        { "type": "text", "id": "cta_label", "label": "t:sections.product_grid.blocks.promo_tile.cta_label", "default": "Shop the drop" },
        { "type": "url", "id": "cta_url", "label": "t:sections.product_grid.blocks.promo_tile.cta_url" }
      ]
    }
  ],
  "presets": [
    { "name": "t:sections.product_grid.name" }
  ]
}
{% endschema %}
