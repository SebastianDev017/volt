<section class="volt-tiers" data-animate>
  <div class="volt-tiers__inner">
    <div class="volt-tiers__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<div class="volt-tiers__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="volt-tiers__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.body != blank -%}<p class="volt-tiers__body">{{ section.settings.body }}</p>{%- endif -%}
    </div>

    <div class="volt-tiers__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign len = 157.08
          assign gv = block.settings.gauge_value | at_least: 0 | at_most: 100
          assign gfill = gv | times: len | divided_by: 100.0
          assign goff = len | minus: gfill
          assign popular = block.settings.popular
          assign accent = block.settings.accent | default: 'mid'
        -%}
        <div class="volt-tier volt-tier--{{ accent }}{% if popular %} volt-tier--popular{% endif %}" {{ block.shopify_attributes }}>
          {%- if popular -%}<div class="volt-tier__flag">{{ 'sections.membership_tiers.most_popular' | t: default: 'Most Popular' }}</div>{%- endif -%}
          <div class="volt-tier__top">
            <div>
              <h3 class="volt-tier__name">{{ block.settings.tier_name }}</h3>
              {%- if block.settings.tagline != blank -%}<div class="volt-tier__tag">{{ block.settings.tagline }}</div>{%- endif -%}
            </div>
            <svg class="volt-tier__gauge" width="92" height="56" viewBox="0 0 120 70" aria-hidden="true">
              <path class="volt-tier__gtrack" d="M10 62 A50 50 0 0 1 110 62" fill="none" stroke-width="9" style="stroke-dasharray:{{ len }}"/>
              <path class="volt-tier__gval" d="M10 62 A50 50 0 0 1 110 62" fill="none" stroke-width="9" stroke-linecap="round" style="stroke-dasharray:{{ len }};stroke-dashoffset:{{ goff }}"/>
              <text x="60" y="58" text-anchor="middle" font-family="DM Mono, monospace" font-size="18" fill="currentColor">{{ gv }}</text>
            </svg>
          </div>

          <div class="volt-tier__price"><span class="volt-tier__amount">{{ block.settings.price }}</span><span class="volt-tier__per">/mo</span></div>
          {%- if block.settings.yearly_line != blank -%}<div class="volt-tier__yearly">{{ block.settings.yearly_line }}</div>{%- endif -%}

          {%- if popular and section.settings.countdown_end_date != blank -%}
            <countdown-timer class="volt-tier__countdown" data-end="{{ section.settings.countdown_end_date }}">
              <span class="volt-tier__cdlabel">{{ 'sections.membership_tiers.offer_ends' | t: default: 'Founding rate ends' }}</span>
              <span class="volt-tier__cdval" data-cd-display>--:--:--</span>
            </countdown-timer>
          {%- endif -%}

          <div class="volt-tier__rule"></div>

          <ul class="volt-tier__feats">
            {%- assign on = block.settings.features_on | newline_to_br | split: '<br />' -%}
            {%- for f in on -%}{%- assign t = f | strip -%}{%- if t != blank -%}<li><span class="volt-tier__yes">✓</span>{{ t }}</li>{%- endif -%}{%- endfor -%}
            {%- assign off = block.settings.features_off | newline_to_br | split: '<br />' -%}
            {%- for f in off -%}{%- assign t = f | strip -%}{%- if t != blank -%}<li class="volt-tier__no"><span>—</span>{{ t }}</li>{%- endif -%}{%- endfor -%}
          </ul>

          <a href="{{ block.settings.cta_link | default: '#' }}" class="volt-tier__cta">{{ block.settings.cta_label | default: 'Choose Protocol' }}</a>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.dashboard_link_label != blank -%}
      <div class="volt-tiers__foot"><a href="{{ section.settings.dashboard_link | default: '#' }}" class="volt-tiers__dash">{{ section.settings.dashboard_link_label }}</a></div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .volt-tiers__inner { max-width: var(--page-width); margin-inline: auto; padding: 90px 28px 80px; }
  .volt-tiers__head { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 20px; margin-bottom: 44px; }
  .volt-tiers__eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--color-mid); }
  .volt-tiers__title { font-family: var(--font-display); font-weight: 700; font-size: clamp(30px, 3vw, 46px); line-height: 1.02; letter-spacing: -.01em; margin: 14px 0 0; }
  .volt-tiers__body { font-size: 14px; line-height: 1.6; color: var(--color-mid); max-width: 38ch; margin: 0; }

  .volt-tiers__grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .volt-tier { border: 1px solid var(--color-border); background: var(--color-bg); padding: 34px 30px; display: flex; flex-direction: column; position: relative; }
  .volt-tier--mid { border-top: 3px solid var(--color-mid); }
  .volt-tier--ink { border-top: 3px solid var(--color-ink); border-left: none; }
  .volt-tier--acid { border-top: 3px solid var(--color-acid); }
  .volt-tier--popular { background: var(--color-ink); color: var(--color-bg); border: 1px solid var(--color-ink); border-top: 3px solid var(--color-acid); margin-top: -14px; }
  .volt-tier__flag { position: absolute; top: 0; right: 24px; transform: translateY(-50%); background: var(--color-acid); color: var(--color-ink); font-family: var(--font-mono); font-size: 9px; letter-spacing: .16em; text-transform: uppercase; padding: 5px 10px; }
  .volt-tier__top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .volt-tier__name { font-family: var(--font-display); font-weight: 700; font-size: 24px; margin: 0; }
  .volt-tier__tag { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--color-mid); margin-top: 6px; }
  .volt-tier--popular .volt-tier__tag { color: rgba(240,238,234,.5); }
  .volt-tier__gauge { flex: none; color: var(--color-ink); }
  .volt-tier--popular .volt-tier__gauge { color: var(--color-bg); }
  .volt-tier__gtrack { stroke: var(--color-border); }
  .volt-tier--popular .volt-tier__gtrack { stroke: rgba(240,238,234,.18); }
  .volt-tier__gval { stroke: var(--color-acid); }
  .volt-tier__price { display: flex; align-items: baseline; gap: 8px; margin: 24px 0 4px; }
  .volt-tier__amount { font-family: var(--font-display); font-weight: 800; font-size: 46px; line-height: 1; }
  .volt-tier--popular .volt-tier__amount { color: var(--color-acid); }
  .volt-tier__per { font-family: var(--font-mono); font-size: 12px; color: var(--color-mid); }
  .volt-tier--popular .volt-tier__per { color: rgba(240,238,234,.6); }
  .volt-tier__yearly { font-family: var(--font-mono); font-size: 11px; color: var(--color-mid); }
  .volt-tier--popular .volt-tier__yearly { color: rgba(240,238,234,.6); }
  .volt-tier__countdown { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: var(--color-acid-10); border: 1px solid rgba(212,255,0,.3); padding: 9px 12px; margin-top: 16px; }
  .volt-tier__cdlabel { font-family: var(--font-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--color-acid); }
  .volt-tier__cdval { font-family: var(--font-mono); font-size: 12px; color: var(--color-bg); }
  .volt-tier__rule { height: 1px; background: var(--color-border); margin: 24px 0; }
  .volt-tier--popular .volt-tier__rule { background: rgba(240,238,234,.15); }
  .volt-tier__feats { list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 13px; font-size: 13px; flex: 1; }
  .volt-tier__feats li { display: flex; align-items: center; gap: 11px; }
  .volt-tier__yes { color: var(--color-acid); font-size: 14px; }
  .volt-tier__no { color: var(--color-mid); }
  .volt-tier--popular .volt-tier__no { color: rgba(240,238,234,.5); }
  .volt-tier__no span { font-size: 14px; }
  .volt-tier__cta { display: block; text-align: center; font-family: var(--font-body); font-weight: 500; font-size: 13px; letter-spacing: .04em; text-transform: uppercase; padding: 15px; cursor: pointer; border: 1px solid var(--color-ink); background: transparent; color: var(--color-ink); text-decoration: none; transition: background var(--dur-med) var(--ease), color var(--dur-med) var(--ease); }
  .volt-tier__cta:hover { background: var(--color-ink); color: var(--color-bg); }
  .volt-tier--popular .volt-tier__cta { background: var(--color-acid); border-color: var(--color-acid); color: var(--color-ink); }
  .volt-tier--popular .volt-tier__cta:hover { filter: brightness(1.05); background: var(--color-acid); color: var(--color-ink); }
  .volt-tiers__foot { text-align: center; margin-top: 32px; }
  .volt-tiers__dash { font-family: var(--font-mono); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border-bottom: 2px solid var(--color-acid); padding-bottom: 3px; }

  @media (max-width: 860px) {
    .volt-tiers__grid { grid-template-columns: 1fr; }
    .volt-tier { border-left: 1px solid var(--color-border); }
    .volt-tier--popular { margin-top: 0; }
  }
{% endstylesheet %}

<script>
  if (!customElements.get('countdown-timer')) {
    customElements.define('countdown-timer', class extends HTMLElement {
      connectedCallback() {
        this.display = this.querySelector('[data-cd-display]');
        this.end = new Date(this.getAttribute('data-end')).getTime();
        if (!this.display || isNaN(this.end)) return;
        this.tick = this.tick.bind(this);
        this.tick();
        this.timer = setInterval(this.tick, 1000);
      }
      disconnectedCallback() { clearInterval(this.timer); }
      pad(n) { return String(n).padStart(2, '0'); }
      tick() {
        let s = Math.floor((this.end - Date.now()) / 1000);
        if (s <= 0) { this.display.textContent = '00:00:00'; clearInterval(this.timer); return; }
        const d = Math.floor(s / 86400); s -= d * 86400;
        const h = Math.floor(s / 3600); s -= h * 3600;
        const m = Math.floor(s / 60); s -= m * 60;
        this.display.textContent = (d > 0 ? d + 'd ' : '') + this.pad(h) + ':' + this.pad(m) + ':' + this.pad(s);
      }
    });
  }
</script>

